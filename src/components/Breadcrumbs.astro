---
/**
 * Breadcrumbs — one shared, accessible breadcrumb trail used by every page
 * template (replacing ~13 inline copies). Visual only; pair with
 * schema.breadcrumbs() for the matching BreadcrumbList JSON-LD. The last item
 * is the current page and must omit `href`.
 */
import type { Locale } from '../data/site';
interface Crumb { name: string; href?: string }
interface Props { items: Crumb[]; locale?: Locale }
const { items, locale = 'en' } = Astro.props;
const navLabel = locale === 'de' ? 'Brotkrümelnavigation' : locale === 'fr' ? 'Fil d’Ariane' : locale === 'it' ? 'Percorso di navigazione' : 'Breadcrumb';
---
<nav class="crumbs container" aria-label={navLabel}>
  <ol>
    {items.map((c, i) => (
      <li>
        {c.href ? <a href={c.href}>{c.name}</a> : <span aria-current="page">{c.name}</span>}
        {i < items.length - 1 && <span class="crumbs__sep" aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .crumbs { padding-top: var(--space-5); }
  .crumbs ol {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem 0.5rem;
    list-style: none; margin: 0; padding: 0;
    font-size: var(--fs-300); color: var(--ink-mute);
  }
  .crumbs li { display: inline-flex; align-items: center; gap: 0.5rem; }
  .crumbs a { color: var(--ink-mute); }
  .crumbs a:hover { color: var(--ink); }
  .crumbs [aria-current='page'] { color: var(--ink-soft); }
  .crumbs__sep { color: var(--ink-mute); }
</style>
