---
/**
 * Site header: real Weissmann logo, primary nav, language switcher, demo CTA.
 * Dark translucent bar over the midnight-violet ground.
 * Mobile: CSS-only disclosure via <details>, no JS dependency.
 */
import { LOCALES, localePrefix, type Locale } from '../data/site';
import type { LocalePaths } from '../data/routes';
import { pillarNav, companyNav, pricingHref } from '../data/nav';
import { t } from '../i18n/ui';

interface Props {
  locale: Locale;
  /** Locale-independent path (legacy German-slug pages). */
  path?: string;
  /** Localized path per locale — preferred; drives the language switcher. */
  localePaths?: LocalePaths;
  availableLocales?: Locale[];
}
const { locale, path, localePaths, availableLocales = [...LOCALES] } = Astro.props;
const p = localePrefix(locale);

// Per-locale paths for the language switcher, from whichever prop was passed.
const lp: LocalePaths | null = localePaths ?? (path ? { de: path, en: path, it: path, fr: path } : null);
const switchTarget = (l: Locale): string =>
  availableLocales.includes(l) && lp ? `${localePrefix(l)}${lp[l]}` : `${localePrefix(l)}/`;

// Six-pillar primary nav (only live pillars) + company links + pricing utility.
const nav = [...pillarNav(locale), ...companyNav(locale)];
const priceHref = pricingHref(locale);
const currentHref = lp ? `${p}${lp[locale]}` : `${p}/`;

const langLabel: Record<Locale, string> = { de: 'DE', en: 'EN', it: 'IT', fr: 'FR' };
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href={`${p}/`} aria-label="Weissmann AI – Home">
      <img src="/logo-weissmann-dark.png" alt="Weissmann AI" width="185" height="80" loading="eager" decoding="async" />
    </a>

    <nav class="site-header__nav" aria-label={locale === 'de' ? 'Hauptnavigation' : locale === 'fr' ? 'Navigation principale' : locale === 'it' ? 'Navigazione principale' : 'Main navigation'}>
      {nav.map((item) => (
        <a href={item.href} aria-current={item.href === currentHref ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a class="site-header__price" href={priceHref}>{t(locale, 'nav.pricing')}</a>
      <nav class="lang-switch" aria-label={t(locale, 'lang.switch')}>
        {LOCALES.map((l) => {
          return l === locale
            ? <span aria-current="true">{langLabel[l]}</span>
            : <a href={switchTarget(l)} hreflang={l}>{langLabel[l]}</a>;
        })}
      </nav>
      <a class="btn btn--primary site-header__cta" href={`${p}/kontakt/`} data-track="request_demo">
        {t(locale, 'nav.cta')}
      </a>
    </div>

    <details class="site-header__mobile">
      <summary aria-label={t(locale, 'nav.menu')}>
        <span class="site-header__burger" aria-hidden="true"></span>
      </summary>
      <div class="site-header__mobile-panel">
        {nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href={priceHref}>{t(locale, 'nav.pricing')}</a>
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="request_demo">{t(locale, 'nav.cta')}</a>
        <div class="lang-switch lang-switch--mobile">
          {LOCALES.map((l) =>
            l === locale
              ? <span aria-current="true">{langLabel[l]}</span>
              : <a href={switchTarget(l)} hreflang={l}>{langLabel[l]}</a>
          )}
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgb(255 255 255 / 0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    min-height: 4.25rem;
  }
  .site-header__brand { display: flex; align-items: center; }
  .site-header__brand img { height: 2.1rem; width: auto; }
  .site-header__nav {
    display: none;
    gap: var(--space-4);
    margin-inline: auto;
  }
  .site-header__nav a {
    color: var(--ink-soft);
    font-weight: 500;
    font-size: var(--fs-300);
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
  }
  .site-header__nav a:hover { color: var(--ink); text-decoration: none; }
  .site-header__nav a[aria-current='page'] { color: var(--accent); }
  .site-header__actions { display: none; align-items: center; gap: var(--space-3); margin-left: auto; }
  .site-header__cta { padding: 0.55rem 1.15rem; font-size: var(--fs-300); }
  .site-header__price { color: var(--ink-soft); font-weight: 500; font-size: var(--fs-300); }
  .site-header__price:hover { color: var(--ink); text-decoration: none; }
  .lang-switch { display: flex; gap: 0.6rem; font-size: var(--fs-300); }
  .lang-switch a { color: var(--ink-mute); }
  .lang-switch a:hover { color: var(--ink); text-decoration: none; }
  .lang-switch span[aria-current] { color: var(--ink); font-weight: 700; }

  .site-header__mobile { margin-left: auto; }
  .site-header__mobile summary {
    list-style: none;
    cursor: pointer;
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 10px;
    border: 1px solid var(--line);
  }
  .site-header__mobile summary::-webkit-details-marker { display: none; }
  .site-header__burger,
  .site-header__burger::before,
  .site-header__burger::after {
    display: block;
    width: 1.1rem;
    height: 1.5px;
    background: var(--ink);
    position: relative;
  }
  .site-header__burger::before, .site-header__burger::after { content: ""; position: absolute; }
  .site-header__burger::before { top: -6px; }
  .site-header__burger::after { top: 6px; }
  .site-header__mobile-panel {
    position: absolute;
    left: 0; right: 0;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
  }
  .site-header__mobile-panel a { color: var(--ink); font-weight: 600; }

  @media (min-width: 920px) {
    .site-header__nav, .site-header__actions { display: flex; }
    .site-header__mobile { display: none; }
  }
</style>
