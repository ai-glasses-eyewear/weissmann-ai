---
/**
 * Site footer: brand, a registry-driven sitemap (Services / Explore / Company /
 * Legal), and the canonical NAP contact rails. Every internal link resolves to
 * a localized URL from the routes registry, so the footer is both a strong
 * internal-linking surface and the safety net that prevents orphan pages.
 * The address renders exclusively from SITE.address — never hardcode it.
 */
import { SITE, localePrefix, type Locale } from '../data/site';
import { pillarHome, relFor } from '../data/routes';
import { getService, servicePaths } from '../data/services';
import { hasGlossary, glossaryHubPaths } from '../data/glossary';
import { liveCompanyPages, companyPagePaths } from '../data/company';
import { t } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
const p = localePrefix(locale);
const year = 2026;

const L: Record<Locale, { all: string; explore: string; academy: string; glossary: string; resources: string; industries: string }> = {
  de: { all: 'Alle Leistungen', explore: 'Entdecken', academy: 'AI Academy', glossary: 'KI-Glossar', resources: 'Ressourcen', industries: 'Branchen' },
  en: { all: 'All services', explore: 'Explore', academy: 'AI Academy', glossary: 'AI Glossary', resources: 'Resources', industries: 'Industries' },
  it: { all: 'Tutti i servizi', explore: 'Esplora', academy: 'AI Academy', glossary: 'Glossario AI', resources: 'Risorse', industries: 'Settori' },
  fr: { all: 'Tous les services', explore: 'Explorer', academy: 'AI Academy', glossary: 'Glossaire IA', resources: 'Ressources', industries: 'Secteurs' },
};
const lbl = L[locale];

const topServices = ['phone-assistant', 'websites', 'seo', 'geo'].map((id) => getService(id)).filter((s) => !!s);
const glossHref = hasGlossary() ? relFor(locale, glossaryHubPaths()) : null;
const companyPages = liveCompanyPages();
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__brandcol">
        <p class="site-footer__brand">
          <img src="/logo-weissmann.png" alt="Weissmann AI" width="185" height="80" loading="lazy" decoding="async" />
        </p>
        <p class="site-footer__tagline">{t(locale, 'footer.tagline')}</p>
        <p class="muted mt-3">{t(locale, 'footer.follow')}:</p>
        <p class="site-footer__social">
          <a href={SITE.social.linkedin} rel="noopener" target="_blank">LinkedIn</a>
          <a href={SITE.social.instagram} rel="noopener" target="_blank">Instagram</a>
          <a href={SITE.social.facebook} rel="noopener" target="_blank">Facebook</a>
          <a href={SITE.social.x} rel="noopener" target="_blank">X</a>
        </p>
      </div>

      <nav class="site-footer__col" aria-label={t(locale, 'nav.services')}>
        <h2 class="site-footer__title">{t(locale, 'nav.services')}</h2>
        <ul class="site-footer__list">
          <li><a href={relFor(locale, pillarHome('services'))}>{lbl.all}</a></li>
          {topServices.map((s) => <li><a href={relFor(locale, servicePaths(s))}>{s.name[locale]}</a></li>)}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label={lbl.explore}>
        <h2 class="site-footer__title">{lbl.explore}</h2>
        <ul class="site-footer__list">
          <li><a href={relFor(locale, pillarHome('industries'))}>{lbl.industries}</a></li>
          <li><a href={relFor(locale, pillarHome('academy'))}>{lbl.academy}</a></li>
          {glossHref && <li><a href={glossHref}>{lbl.glossary}</a></li>}
          <li><a href={relFor(locale, pillarHome('resources'))}>{lbl.resources}</a></li>
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label={t(locale, 'nav.company')}>
        <h2 class="site-footer__title">{t(locale, 'nav.company')}</h2>
        <ul class="site-footer__list">
          <li><a href={`${p}/ueber-uns/`}>{t(locale, 'nav.about')}</a></li>
          {companyPages.map((c) => <li><a href={relFor(locale, companyPagePaths(c))}>{c.name[locale]}</a></li>)}
          <li><a href={`${p}/preise/`}>{t(locale, 'nav.pricing')}</a></li>
          <li><a href={`${p}/kontakt/`}>{t(locale, 'nav.contact')}</a></li>
        </ul>
        <h2 class="site-footer__title mt-4">{t(locale, 'footer.legalTitle')}</h2>
        <ul class="site-footer__list">
          <li><a href={`${p}/impressum/`}>{t(locale, 'footer.impressum')}</a></li>
          <li><a href={`${p}/datenschutz/`}>{t(locale, 'footer.privacy')}</a></li>
          <li><a href={`${p}/agb/`}>{t(locale, 'footer.terms')}</a></li>
        </ul>
      </nav>

      <div class="site-footer__col">
        <h2 class="site-footer__title">{t(locale, 'footer.contactTitle')}</h2>
        <address class="site-footer__address">
          Weissmann AI<br />
          {SITE.address.street}<br />
          {SITE.address.postalCode} {SITE.address.city}<br />
          {SITE.address.country[locale]}
        </address>
        <ul class="site-footer__list mt-3">
          <li><a href={`tel:${SITE.phone}`} data-track="phone_click">{SITE.phoneDisplay}</a></li>
          <li><a href={`mailto:${SITE.email}`} data-track="email_click">{SITE.email}</a></li>
          <li><a href={SITE.whatsapp} rel="noopener" target="_blank" data-track="whatsapp_click">WhatsApp</a></li>
        </ul>
      </div>
    </div>

    <p class="site-footer__copyright">© {year} Weissmann AI. {t(locale, 'footer.rights')}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark-bg);
    color: var(--dark-mute);
    padding-block: var(--space-6) var(--space-4);
    margin-top: var(--space-7);
  }
  .site-footer a { color: var(--dark-mute); }
  .site-footer a:hover { color: var(--dark-ink); }
  .site-footer__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-5); }
  .site-footer__brand img { height: 2rem; width: auto; }
  .site-footer__tagline { margin-top: var(--space-2); font-size: var(--fs-300); max-width: 26rem; }
  .site-footer__social { display: flex; gap: var(--space-3); margin-top: var(--space-1); font-size: var(--fs-300); }
  .site-footer__title {
    font-size: var(--fs-300);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dark-mute);
    margin-bottom: var(--space-2);
  }
  .site-footer__list { list-style: none; padding: 0; margin: 0; font-size: var(--fs-300); }
  .site-footer__list li + li { margin-top: var(--space-2); }
  .site-footer__address { font-style: normal; font-size: var(--fs-300); line-height: 1.7; }
  .site-footer__copyright {
    margin-top: var(--space-5);
    padding-top: var(--space-3);
    border-top: 1px solid var(--dark-line);
    font-size: var(--fs-300);
    color: var(--dark-mute);
  }
  @media (min-width: 560px) { .site-footer__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .site-footer__grid { grid-template-columns: 1.6fr 1fr 1fr 1.2fr 1.2fr; } .site-footer__brandcol { grid-row: span 1; } }
</style>
