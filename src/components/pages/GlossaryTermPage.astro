---
/**
 * GlossaryTermPage — a single AI Glossary term (/ki-academy/glossar/{term}/).
 * Answer-first definition as the citeable core, DefinedTerm schema, and the
 * internal-linking spine: related terms, the commercial service it operationa-
 * lizes, and the Academy articles that explain it in depth.
 */
import { SITE, HTML_LANG, type Locale } from '../../data/site';
import { type LocalePaths, pillarHome, urlFor, relFor } from '../../data/routes';
import { type GlossaryTerm, glossaryHubPaths, termPaths, getTerm } from '../../data/glossary';
import { getService, servicePaths } from '../../data/services';
import { ARTICLES, articlePaths } from '../../data/academy';
import { breadcrumbs } from '../../data/schema';
import { t } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../Breadcrumbs.astro';

interface Props { locale: Locale; localePaths: LocalePaths; term: GlossaryTerm }
const { locale, localePaths, term } = Astro.props;

const LBL: Record<Locale, { academy: string; glossary: string; related: string; service: string; read: string; back: string; def: string }> = {
  de: { academy: 'AI Academy', glossary: 'Glossar', related: 'Verwandte Begriffe', service: 'Passende Leistung', read: 'Mehr dazu in der Academy', back: 'Zum Glossar', def: 'Definition' },
  en: { academy: 'AI Academy', glossary: 'Glossary', related: 'Related terms', service: 'Related service', read: 'Read more in the Academy', back: 'Back to glossary', def: 'Definition' },
  it: { academy: 'AI Academy', glossary: 'Glossario', related: 'Termini correlati', service: 'Servizio pertinente', read: 'Approfondisci nell’Academy', back: 'Torna al glossario', def: 'Definizione' },
  fr: { academy: 'AI Academy', glossary: 'Glossaire', related: 'Termes liés', service: 'Service pertinent', read: 'En savoir plus dans l’Academy', back: 'Retour au glossaire', def: 'Définition' },
};
const lbl = LBL[locale];
const pre = locale === 'de' ? '' : `/${locale}`;
const academyHub = pillarHome('academy');
const gloss = glossaryHubPaths();

const relTerms = (term.relatedTerms ?? []).map((id) => getTerm(id)).filter((x): x is GlossaryTerm => !!x);
const relServices = (term.relatedServices ?? []).map((id) => getService(id)).filter((s): s is NonNullable<typeof s> => !!s && s.status === 'live');
const relArticles = (term.relatedArticles ?? []).map((id) => ARTICLES.find((a) => a.id === id)).filter((a): a is NonNullable<typeof a> => !!a);

const crumbHome = { de: 'Startseite', en: 'Home', it: 'Home', fr: 'Accueil' }[locale];
// Keep the "— Definition" signal for short terms, but drop it when it would
// push the title past the ~65-char SERP budget (long legal/expanded terms).
const withDef = `${term.term[locale]} — ${lbl.def}`;
const title = `${withDef.length <= 50 ? withDef : term.term[locale]} | Weissmann AI`;

const schema = [
  {
    '@type': 'DefinedTerm',
    '@id': `${urlFor(locale, localePaths)}#term`,
    name: term.term[locale],
    description: term.definition[locale],
    inDefinedTermSet: urlFor(locale, gloss),
    termCode: term.id,
    inLanguage: HTML_LANG[locale],
  },
  breadcrumbs(locale, [
    { name: crumbHome, path: '/' },
    { name: lbl.academy, path: academyHub[locale] },
    { name: lbl.glossary, path: gloss[locale] },
    { name: term.term[locale], path: localePaths[locale] },
  ]),
];
---
<Layout locale={locale} localePaths={localePaths} title={title} description={term.definition[locale]} schema={schema}>
  <Breadcrumbs items={[
    { name: crumbHome, href: `${pre}/` },
    { name: lbl.academy, href: relFor(locale, academyHub) },
    { name: lbl.glossary, href: relFor(locale, gloss) },
    { name: term.term[locale] },
  ]} />

  <article class="term container">
    <p class="kicker">{lbl.def}</p>
    <h1>{term.term[locale]}</h1>
    <p class="term-def">{term.definition[locale]}</p>
    {term.extended?.[locale] && <p class="term-ext">{term.extended[locale]}</p>}

    {relServices.length > 0 && (
      <div class="term-block">
        <h2>{lbl.service}</h2>
        <div class="term-cards">
          {relServices.map((s) => (
            <a class="term-card" href={relFor(locale, servicePaths(s))}><strong>{s.name[locale]}</strong><span>{s.tagline[locale]}</span></a>
          ))}
        </div>
      </div>
    )}

    {relArticles.length > 0 && (
      <div class="term-block">
        <h2>{lbl.read}</h2>
        <ul class="term-links">
          {relArticles.map((a) => <li><a href={relFor(locale, articlePaths(a))}>{a.h1[locale]}</a></li>)}
        </ul>
      </div>
    )}

    {relTerms.length > 0 && (
      <div class="term-block">
        <h2>{lbl.related}</h2>
        <div class="term-chips">
          {relTerms.map((rt) => <a class="chip" href={relFor(locale, termPaths(rt))}>{rt.term[locale]}</a>)}
        </div>
      </div>
    )}

    <p class="term-back"><a href={relFor(locale, gloss)}>← {lbl.back}</a></p>
  </article>
</Layout>

<style>
  .term { max-width: 46rem; padding-top: var(--space-5); padding-bottom: var(--space-7); }
  .kicker { text-transform: uppercase; letter-spacing: 0.12em; font-size: var(--fs-200); color: var(--accent); font-weight: 600; }
  .term h1 { font-size: var(--fs-700); margin: 0.4rem 0 1rem; }
  .term-def { font-size: var(--fs-500); color: var(--ink); line-height: 1.5; }
  .term-ext { color: var(--ink-soft); line-height: 1.7; margin-top: var(--space-3); }
  .term-block { margin-top: var(--space-5); }
  .term-block h2 { font-size: var(--fs-300); text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-mute); margin-bottom: var(--space-3); }
  .term-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: var(--space-3); }
  .term-card { border: 1px solid var(--line); border-radius: 12px; padding: var(--space-3) var(--space-4); background: var(--paper); display: flex; flex-direction: column; gap: 0.2rem; }
  .term-card:hover { border-color: var(--accent); text-decoration: none; }
  .term-card strong { color: var(--ink); }
  .term-card span { color: var(--ink-soft); font-size: var(--fs-300); }
  .term-links { display: flex; flex-direction: column; gap: 0.5rem; padding-left: 1.1rem; }
  .term-links a { color: var(--accent); }
  .term-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .chip { border: 1px solid var(--line); border-radius: 999px; padding: 0.35rem 0.9rem; font-size: var(--fs-300); color: var(--ink-soft); }
  .chip:hover { border-color: var(--accent); color: var(--ink); text-decoration: none; }
  .term-back { margin-top: var(--space-6); }
  .term-back a { color: var(--accent); font-weight: 600; }
</style>
