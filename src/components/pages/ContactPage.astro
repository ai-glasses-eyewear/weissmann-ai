    demoHeading: 'Buchen Sie Ihre 15-Minuten-Demo',
    demoSub:
      'Erleben Sie Ihren eigenen KI-Telefonassistenten an einem echten Anruf – kostenlos und unverbindlich.',
    demoStepsTitle: 'Das passiert in Ihren 15 Minuten:',
    demoSteps: [
      'Wir richten einen kurzen Test ein, konfiguriert mit den Angaben zu Ihrem Unternehmen.',
      'Sie hören live, wie die KI einen Anruf annimmt, einen Termin bucht und eine Zusammenfassung per WhatsApp oder E-Mail sendet.',
      'Ein ehrliches Ja oder Nein, ob es zu Ihrem Unternehmen passt – ganz ohne Druck.',
    ],
    demoBook: '15-Minuten-Demo buchen',
    demoReassure: 'Kostenlos · ca. 15 Min. · keine Vorbereitung nötig · unverbindlich',
    demoFormNote: 'Lieber schreiben? Senden Sie uns dies und wir richten Ihre Demo ein.',
    directTitle: 'Direkter Draht',
    callaiHeading: 'Noch nicht bereit fürs Formular?',
    callaiNote: 'Sie sprechen mit unserer echten KI – kostenlos und unverbindlich.',
    directLead: 'Lieber direkt anrufen oder schreiben?',
    callLabel: 'Anrufen:',
    emailLabel: 'E-Mail:',
    services: [
      'KI-Telefonassistent',
      'Website',
      'SEO',
      'GEO / KI-Suche',
      'Google Ads',
      'Automatisierung',
      'KI-Beratung',
      'Anderes',
    ],
    langs: ['Deutsch', 'English', 'Français', 'Italiano'],
  },
  en: {
    metaTitle: 'Contact | Weissmann AI – Practical AI consulting in Zurich',
    metaDesc:
      'Contact Weissmann AI in Zurich: free initial consultation on AI phone agents, websites, SEO, GEO and automation. Phone, email or WhatsApp.',
    h1: 'Let’s talk about your business',
    intro:
      'Tell us briefly where you stand and what you want to achieve. We’ll get back to you within one business day — honest, concrete and without sales pressure.',
    demoEyebrow: 'Live demo',
    demoHeading: 'Book your 15-minute demo',
    demoSub:
      'Experience your own AI phone assistant on a real call — free and with no obligation.',
    demoStepsTitle: 'What happens in your 15 minutes:',
    demoSteps: [
      'We set up a short test, configured with your business information.',
      'You hear the AI answer a call, book an appointment and send a WhatsApp or email summary — live.',
      'An honest yes or no on whether it fits your business — no pressure.',
    ],
    demoBook: 'Book a 15-min demo',
    demoReassure: 'Free · ~15 min · no preparation needed · no obligation',
    demoFormNote: 'Prefer to write? Send this and we’ll set up your demo.',
    directTitle: 'Direct line',
    callaiHeading: 'Not ready for a form?',
    callaiNote: 'You’ll be speaking with our real AI assistant – free and no obligation.',
    directLead: 'Prefer to talk instead?',
    callLabel: 'Call us:',
    emailLabel: 'Email:',
    services: [
      'AI Phone Agent',
      'Website',
      'SEO',
      'GEO / AI search',
      'Google Ads',
      'Automation',
      'AI Consulting',
      'Other',
    ],
    langs: ['Deutsch', 'English', 'Français', 'Italiano'],
  },
  it: {
    metaTitle: 'Contatto | Weissmann AI – Consulenza di AI pratica a Zurigo',
    metaDesc:
      'Contattate Weissmann AI a Zurigo: prima consulenza gratuita su assistenti telefonici AI, siti web, SEO, GEO e automazione. Telefono, e-mail o WhatsApp.',
    h1: 'Parliamo della vostra azienda',
    intro:
      'Raccontateci brevemente a che punto siete e cosa volete raggiungere. Vi rispondiamo entro un giorno lavorativo — con onestà, concretezza e senza pressione commerciale.',
    demoEyebrow: 'Demo dal vivo',
    demoHeading: 'Prenotate la vostra demo di 15 minuti',
    demoSub:
      'Provate il vostro assistente telefonico AI durante una chiamata reale — gratis e senza impegno.',
    demoStepsTitle: 'Cosa succede nei vostri 15 minuti:',
    demoSteps: [
      'Configuriamo un breve test con le informazioni della vostra azienda.',
      'Sentite l’AI rispondere a una chiamata, fissare un appuntamento e inviare un riepilogo via WhatsApp o e-mail — dal vivo.',
      'Un sì o un no onesto sul fatto che sia adatta alla vostra azienda — senza pressioni.',
    ],
    demoBook: 'Prenota una demo di 15 min',
    demoReassure: 'Gratis · ~15 min · nessuna preparazione necessaria · senza impegno',
    demoFormNote: 'Preferite scrivere? Inviateci questo e prepareremo la vostra demo.',
    directTitle: 'Linea diretta',
    callaiHeading: 'Non ancora pronti per il modulo?',
    callaiNote: 'Parlate con la nostra vera AI – gratis e senza impegno.',
    directLead: 'Preferite contattarci direttamente?',
    callLabel: 'Chiamateci:',
    emailLabel: 'E-mail:',
    services: [
      'Assistente telefonico AI',
      'Sito web',
      'SEO',
      'GEO / ricerca AI',
      'Google Ads',
      'Automazione',
      'Consulenza AI',
      'Altro',
    ],
    langs: ['Deutsch', 'English', 'Français', 'Italiano'],
  },
  fr: {
    metaTitle: 'Contact | Weissmann AI – Conseil en IA pratique à Zurich',
    metaDesc:
      'Contactez Weissmann AI à Zurich : première consultation gratuite sur les agents téléphoniques IA, sites web, SEO, GEO et automatisation. Téléphone, e-mail ou WhatsApp.',
    h1: 'Parlons de votre entreprise',
    intro:
      'Dites-nous brièvement où vous en êtes et ce que vous voulez atteindre. Nous vous répondons sous un jour ouvrable — honnêtement, concrètement et sans pression commerciale.',
    demoEyebrow: 'Démo en direct',
    demoHeading: 'Réservez votre démo de 15 minutes',
    demoSub:
      'Découvrez votre propre assistant téléphonique IA lors d’un véritable appel — gratuit et sans engagement.',
    demoStepsTitle: 'Ce qui se passe pendant vos 15 minutes :',
    demoSteps: [
      'Nous configurons un court test avec les informations de votre entreprise.',
      'Vous entendez l’IA répondre à un appel, prendre un rendez-vous et envoyer un récapitulatif par WhatsApp ou e-mail — en direct.',
      'Un oui ou un non honnête sur son adéquation à votre entreprise — sans pression.',
    ],
    demoBook: 'Réserver une démo de 15 min',
    demoReassure: 'Gratuit · ~15 min · aucune préparation nécessaire · sans engagement',
    demoFormNote: 'Vous préférez écrire ? Envoyez-nous ceci et nous préparerons votre démo.',
    directTitle: 'Ligne directe',
    callaiHeading: 'Pas encore prêt pour le formulaire ?',
    callaiNote: 'Vous parlez à notre véritable IA – gratuit et sans engagement.',
    directLead: 'Vous préférez nous parler directement ?',
    callLabel: 'Appelez-nous :',
    emailLabel: 'E-mail :',
    services: [
      'Agent téléphonique IA',
      'Site web',
      'SEO',
      'GEO / recherche IA',
      'Google Ads',
      'Automatisation',
      'Conseil IA',
      'Autre',
    ],
    langs: ['Deutsch', 'English', 'Français', 'Italiano'],
  },
};
const c = C[locale];

const schema = [
  webPage(locale, PATH, c.metaTitle, c.metaDesc),
  breadcrumbs(locale, [
    { name: t(locale, 'breadcrumb.home'), path: '/' },
    { name: t(locale, 'nav.contact'), path: PATH },
  ]),
];
---

<Layout locale={locale} path={PATH} title={c.metaTitle} description={c.metaDesc} schema={schema}>
  <section class="section">
    <div class="container">
      <span class="eyebrow">{t(locale, 'nav.contact')}</span>
      <h1 style="max-width:40rem;">{c.h1}</h1>
      <p class="prose mt-4" style="font-size:var(--fs-500);">{c.intro}</p>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="card demo-band">
        <div class="demo-band__head">
          <span class="eyebrow">{c.demoEyebrow}</span>
          <h2 class="demo-band__title">{c.demoHeading}</h2>
          <p class="demo-band__sub">{c.demoSub}</p>
        </div>
        <div class="demo-band__body">
          <div class="demo-band__steps">
            <p class="demo-band__stepsTitle">{c.demoStepsTitle}</p>
            <ul class="checklist demo-band__list">
              {c.demoSteps.map((s: string) => <li>{s}</li>)}
            </ul>
          </div>
          <div class="demo-band__cta">
            <a class="btn btn--primary" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live"><Icon name="phone" size={18} />{t(locale, 'cta.callAi')} · {SITE.aiPhoneDisplay}</a>
            {BOOKING.scheduleUrl
              ? <a class="btn btn--secondary" href={BOOKING.scheduleUrl} target="_blank" rel="noopener" data-track="book_consultation"><Icon name="calendar-check" size={18} />{c.demoBook}</a>
              : <a class="btn btn--secondary" href="#demo-form" data-track="book_consultation"><Icon name="calendar-check" size={18} />{c.demoBook}</a>}
            <p class="demo-band__reassure">{c.demoReassure}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="grid grid--2" style="align-items:start;">
        <form
          id="demo-form"
          class="card card--raised"
          name="kontakt"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action={`${p}/danke/`}
          data-contact-form
        >
          <input type="hidden" name="form-name" value="kontakt" />
          <input type="hidden" name="locale" value={locale} />
          <p hidden aria-hidden="true">
            <label>Bot field<input name="bot-field" /></label>
          </p>
          <p class="form-lead">{c.demoFormNote}</p>

          <div class="field">
            <label for="cf-name">{t(locale, 'form.name')} *</label>
            <input id="cf-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="cf-email">{t(locale, 'form.email')} *</label>
            <input id="cf-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="cf-company">{t(locale, 'form.company')}</label>
            <input id="cf-company" name="company" type="text" autocomplete="organization" />
          </div>
          <div class="field">
            <label for="cf-phone">{t(locale, 'form.phone')}</label>
            <input id="cf-phone" name="phone" type="tel" autocomplete="tel" />
          </div>
          <div class="field">
            <label for="cf-service">{t(locale, 'form.service')}</label>
            <select id="cf-service" name="service">
              <option value="" disabled selected>{t(locale, 'form.select')}</option>
              {c.services.map((s: string) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="cf-website">{t(locale, 'form.website')}</label>
            <input id="cf-website" name="website" type="url" placeholder="https://" />
          </div>
          <div class="field">
            <label for="cf-language">{t(locale, 'form.language')}</label>
            <select id="cf-language" name="preferred_language">
              {c.langs.map((l: string) => <option value={l}>{l}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="cf-message">{t(locale, 'form.challenge')}</label>
            <textarea id="cf-message" name="message" rows="5" maxlength="5000"></textarea>
          </div>
          <div class="field field--consent">
            <input id="cf-consent" name="consent" type="checkbox" required />
            <label for="cf-consent">{t(locale, 'form.consentPre')}<a href={`${p}/datenschutz/`}>{t(locale, 'form.consentPolicy')}</a>{t(locale, 'form.consentPost')}</label>
          </div>
          <button class="btn btn--primary" type="submit">{t(locale, 'form.submit')}</button>
        </form>

        <div class="contact-aside">
          <div class="card contact-callai">
            <h2 style="font-size:var(--fs-600);">{c.callaiHeading}</h2>
            <a class="btn btn--accent contact-callai__cta" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live">{t(locale, 'cta.callAi')} · {SITE.aiPhoneDisplay}</a>
            <p class="contact-callai__note">{c.callaiNote}</p>
          </div>
          <div class="card">
            <h2 style="font-size:var(--fs-600);">{c.directTitle}</h2>
            <p class="mt-3" style="color:var(--ink-soft);">{c.directLead}</p>
            <ul class="checklist">
              <li><a href={`tel:${SITE.phone}`} data-track="phone_click">{c.callLabel} {SITE.phoneDisplay}</a></li>
              <li><a href={`mailto:${SITE.email}`} data-track="email_click">{c.emailLabel} {SITE.email}</a></li>
              <li><a href={SITE.whatsapp} rel="noopener" target="_blank" data-track="whatsapp_click">{t(locale, 'cta.whatsapp')}</a></li>
            </ul>
            <address class="mt-4" style="font-style:normal;color:var(--ink-soft);">
              <strong>Weissmann AI</strong><br />
              {SITE.address.street}<br />
              {SITE.address.postalCode} {SITE.address.city}<br />
              {SITE.address.country[locale]}
            </address>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Accent button — mirrors the homepage accent style, which is component-scoped (not global). */
  .btn--accent { background: #4f7cf0; color: #fff; box-shadow: 0 12px 30px -6px rgba(79,124,240,0.45); }
  .btn--accent:hover { background: #6c92f6; }

  /* "Book a 15-minute demo" highlighted band */
  .demo-band {
    background: var(--accent-soft);
    border-color: color-mix(in srgb, var(--accent) 24%, transparent);
  }
  .demo-band__title { margin-top: var(--space-2); font-size: var(--fs-700); max-width: 32rem; }
  .demo-band__sub { margin-top: var(--space-3); margin-bottom: 0; color: var(--ink-soft); font-size: var(--fs-500); max-width: 40rem; }
  .demo-band__body { display: grid; gap: var(--space-4); margin-top: var(--space-5); }
  .demo-band__stepsTitle { margin: 0; font-weight: 600; color: var(--ink); }
  .demo-band__list { margin-top: var(--space-3); }
  .demo-band__cta { display: flex; flex-direction: column; gap: var(--space-3); align-content: start; }
  .demo-band__cta .btn { width: 100%; }
  .demo-band__reassure { margin: 0; color: var(--ink-soft); font-size: var(--fs-300); }

  @media (min-width: 760px) {
    .demo-band__body { grid-template-columns: 1fr minmax(15rem, 20rem); gap: var(--space-6); align-items: start; }
  }

  /* Small lead framing the contact form as the demo-request form */
  .form-lead { margin: 0 0 var(--space-4); color: var(--ink-soft); font-size: var(--fs-300); }

  /* "Call our AI live" highlight block */
  .contact-callai { border-color: rgba(79,124,240,0.45); background: rgba(79,124,240,0.05); }
  .contact-callai__cta { margin-top: var(--space-3); width: 100%; }
  .contact-callai__note { margin-top: var(--space-3); margin-bottom: 0; color: var(--ink-soft); font-size: var(--fs-300); }

  /* Mobile-first: dissolve the aside so its cards join the grid directly,
     letting the call-AI block render ABOVE the form while the form stays primary. */
  .contact-aside { display: contents; }
  .contact-callai { order: -1; }

  @media (min-width: 760px) {
    /* Desktop: aside is the right-hand column with both cards stacked. */
    .contact-aside { display: grid; gap: var(--space-4); align-content: start; }
    .contact-callai { order: 0; }
  }
</style>

<script is:inline>
  (function () {
    var form = document.querySelector('[data-contact-form]');
    if (!form) return;
    var started = false;
    form.addEventListener('input', function () {
      if (started) return;
      started = true;
      if (window.wmEvent) window.wmEvent('form_start', { form: 'kontakt' });
    });
    form.addEventListener('submit', function () {
      if (window.wmEvent) window.wmEvent('form_submit', { form: 'kontakt' });
      if (window.wmEvent) window.wmEvent('generate_lead', { form: 'kontakt' });
    });
  })();
</script>
