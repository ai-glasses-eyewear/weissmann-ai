      seo: 'Scopri il servizio SEO',
      geo: 'Scopri GEO – Generative Engine Optimization',
      ads: 'Scopri Google Ads',
    },
    faqTitle: 'Domande frequenti su prezzi e contratti',
    faq: [
      { q: 'I prezzi includono l’IVA?', a: 'Tutti i prezzi si intendono IVA esclusa.' },
      { q: 'Ci sono costi nascosti?', a: 'No. Ogni pacchetto definisce perimetro ed esclusioni in modo trasparente. I costi di terzi (come il budget pubblicitario per Google Ads) sono chiaramente indicati e pagati direttamente da voi.' },
      { q: 'Come funziona il pagamento?', a: 'I pacchetti Starter e Premium dell’assistente telefonico possono essere sottoscritti direttamente online via Stripe. Per tutti gli altri iniziamo con una breve consulenza, perché il perimetro sia davvero adatto.' },
      { q: 'Quali durate contrattuali si applicano?', a: 'Assistente telefonico Starter e Premium: 12 mesi. Per i pacchetti marketing mensili discutiamo la durata minima raccomandata in modo trasparente nel primo colloquio.' },
      { q: 'E se il mio progetto non rientra in un pacchetto?', a: 'Allora creiamo un’offerta personalizzata basata su un’analisi del perimetro — ad esempio per siti più grandi da CHF 9’900.' },
      { q: 'Quanto costa un assistente telefonico AI in Svizzera?', a: 'L’assistente telefonico Weissmann AI costa da CHF 350 al mese (Starter, 1500 minuti inclusi) o CHF 590 al mese (Premium, 3500 minuti inclusi). Nessun costo di attivazione, contratto di 12 mesi, tutti i prezzi IVA esclusa.' },
    ],
    phoneAnchor: 'Da CHF 350/mese – meno di CHF 12 al giorno e una frazione di una receptionist (tipicamente CHF 4’000–6’000+/mese). Il vostro assistente telefonico AI risponde a ogni chiamata 24 ore su 24 – anche quando nel team nessuno può rispondere.',
    phoneAnchorLink: 'Fate il calcolo: quanto vi costano le chiamate perse?',
    startTitle: 'Non sapete da dove iniziare?',
    startText: 'La maggior parte delle aziende inizia con l’assistente telefonico AI – l’unico pacchetto che potete sottoscrivere subito online. Indecisi? Prenotate una breve chiamata e vi consiglieremo onestamente la soluzione giusta.',
    startCta1: 'Vai ai pacchetti dell’assistente telefonico',
    badgeWebsite: 'Consigliato',
    ctaTitle: 'Non sapete quale pacchetto fa per voi?',
    ctaText: 'In una breve conversazione scopriamo insieme cosa avrà davvero effetto per la vostra azienda.',
  },
  fr: {
    metaTitle: 'Tarifs et forfaits : services IA à prix fixe | Weissmann AI',
    metaDesc:
      'Tarifs transparents de Weissmann AI : agent téléphonique IA dès CHF 350/mois, sites web dès CHF 2’490, SEO dès CHF 890/mois, GEO dès CHF 990/mois, Google Ads dès CHF 690/mois.',
    h1: 'Des prix clairs. Un périmètre clair. Pas de surprises.',
    intro:
      'Chaque forfait a un périmètre défini, des limites transparentes et un objectif clair. Si quelque chose ne convient pas, nous vous le disons honnêtement — avant tout achat.',
    tldr:
      'En bref : agent téléphonique IA dès CHF 350/mois, sites web dès CHF 2’490, SEO dès CHF 890/mois, GEO dès CHF 990/mois, Google Ads dès CHF 690/mois — tous les prix hors TVA.',
    groups: {
      'phone-agent': 'Agent téléphonique IA',
      website: 'Sites web',
      seo: 'SEO',
      geo: 'GEO – Visibilité dans la recherche IA',
      ads: 'Google Ads',
    },
    moreLinks: {
      'phone-agent': 'En savoir plus sur l’assistant téléphonique IA',
      website: 'En savoir plus sur le développement web IA',
      seo: 'En savoir plus sur le SEO',
      geo: 'En savoir plus sur le GEO – Generative Engine Optimization',
      ads: 'En savoir plus sur Google Ads',
    },
    faqTitle: 'Questions fréquentes sur les tarifs et contrats',
    faq: [
      { q: 'Les prix incluent-ils la TVA ?', a: 'Tous les prix s’entendent hors TVA.' },
      { q: 'Y a-t-il des coûts cachés ?', a: 'Non. Chaque forfait définit le périmètre et les exclusions de façon transparente. Les coûts tiers (comme le budget publicitaire Google Ads) sont clairement indiqués et payés directement par vous.' },
      { q: 'Comment fonctionne le paiement ?', a: 'Les forfaits Starter et Premium de l’agent téléphonique peuvent être souscrits directement en ligne via Stripe. Pour tous les autres, nous commençons par une courte consultation afin que le périmètre convienne vraiment.' },
      { q: 'Quelles durées contractuelles s’appliquent ?', a: 'Agent téléphonique Starter et Premium : 12 mois. Pour les forfaits marketing mensuels, nous discutons de la durée minimale recommandée en toute transparence lors du premier entretien.' },
      { q: 'Et si mon projet ne rentre dans aucun forfait ?', a: 'Nous créons alors une offre sur mesure basée sur une analyse du périmètre — par exemple pour les sites plus grands dès CHF 9’900.' },
      { q: 'Combien coûte un agent téléphonique IA en Suisse ?', a: 'L’agent téléphonique Weissmann AI coûte à partir de CHF 350 par mois (Starter, 1500 minutes incluses) ou CHF 590 par mois (Premium, 3500 minutes incluses). Aucuns frais d’installation, contrat de 12 mois, tous les prix hors TVA.' },
    ],
    phoneAnchor: 'Dès CHF 350/mois – moins de CHF 12 par jour et une fraction d’une réceptionniste (typiquement CHF 4’000–6’000+/mois). Votre agent téléphonique IA répond à chaque appel 24h/24 – même quand personne dans l’équipe ne peut décrocher.',
    phoneAnchorLink: 'Faites le calcul : combien vous coûtent les appels manqués ?',
    startTitle: 'Vous ne savez pas par où commencer ?',
    startText: 'La plupart des entreprises commencent par l’agent téléphonique IA – le seul forfait souscriptible en ligne immédiatement. Hésitant ? Réservez un court entretien et nous vous recommanderons honnêtement la bonne solution.',
    startCta1: 'Voir les forfaits de l’agent téléphonique',
    badgeWebsite: 'Recommandé',
    ctaTitle: 'Pas sûr du forfait qui convient ?',
    ctaText: 'Lors d’un court entretien, nous déterminons ensemble ce qui aura un réel impact pour votre entreprise.',
  },
};
const c = C[locale];

// Link the point-of-price receptionist/missed-call anchor to the existing
// missed-calls ROI calculator resource (never a hardcoded URL).
const roi = getResource('phone-roi-calculator');
const roiHref = roi ? relFor(locale, resourcePaths(roi)) : `${p}/`;

const order: Array<keyof typeof c.groups> = ['phone-agent', 'website', 'seo', 'geo', 'ads'];

// Each price group links to its canonical service page (locale-correct, via the
// route registry — never a hardcoded URL). Groups whose service is missing or
// not live simply render without a link.
const SERVICE_FOR_GROUP: Record<string, string> = {
  'phone-agent': 'phone-assistant',
  website: 'websites',
  seo: 'seo',
  geo: 'geo',
  ads: 'google-ads',
};
const serviceLinkFor = (cat: string): { href: string; label: string } | null => {
  const s = getService(SERVICE_FOR_GROUP[cat]);
  if (!s || s.status !== 'live') return null;
  return { href: relFor(locale, servicePaths(s)), label: c.moreLinks[cat] };
};

const schema = [
  webPage(locale, PATH, c.metaTitle, c.metaDesc),
  breadcrumbs(locale, [
    { name: t(locale, 'breadcrumb.home'), path: '/' },
    { name: t(locale, 'nav.pricing'), path: PATH },
  ]),
  allPackageServices(locale, PATH),
  faqPage(c.faq),
];
---

<Layout locale={locale} path={PATH} title={c.metaTitle} description={c.metaDesc} schema={schema}>
  <section class="section">
    <div class="container">
      <span class="eyebrow">{t(locale, 'nav.pricing')}</span>
      <h1 style="max-width:40rem;">{c.h1}</h1>
      <p class="prose mt-4" style="font-size:var(--fs-500);">{c.intro}</p>
      <p class="muted mt-3" style="max-width:48rem;">{c.tldr}</p>
      <p class="muted mt-3">{t(locale, 'price.vatNote')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card" style="max-width:52rem;">
        <h2 style="font-size:var(--fs-600);">{c.startTitle}</h2>
        <p class="mt-3 prose">{c.startText}</p>
        <div class="mt-3" style="display:flex;gap:var(--space-3);flex-wrap:wrap;">
          <a class="btn btn--primary" href="#phone-plans" data-track="jump_phone_plans">{c.startCta1}</a>
          <a class="btn btn--secondary" href={`${p}/kontakt/`} data-track="book_consultation">{t(locale, 'cta.consultation')}</a>
        </div>
      </div>
    </div>
  </section>

  {order.map((cat, i) => {
    const link = serviceLinkFor(cat as string);
    return (
    <section id={cat === 'phone-agent' ? 'phone-plans' : undefined} class={`section ${i % 2 === 0 ? 'section--alt' : ''}`}>
      <div class="container">
        <div class="section-head">
          <h2>{c.groups[cat]}</h2>
          {link && (
            <p class="muted mt-3"><a href={link.href} data-track="service_view">{link.label} →</a></p>
          )}
        </div>
        {cat === 'phone-agent' && (
          <div class="card" style="background:var(--paper-soft);max-width:52rem;margin-bottom:var(--space-4);">
            <p class="prose">{c.phoneAnchor}</p>
            <p class="mt-3"><a href={roiHref} data-track="roi_calculator_view">{c.phoneAnchorLink} →</a></p>
          </div>
        )}
        <div class="grid grid--3">
          {PACKAGES.filter((pkg) => pkg.category === cat).map((pkg) => (
            <PricingCard pkg={pkg} locale={locale} highlight={pkg.id === 'phone-premium' || pkg.id === 'website-business'} badge={pkg.id === 'website-business' ? c.badgeWebsite : undefined} />
          ))}
        </div>
      </div>
    </section>
    );
  })}

  <section class="section">
    <div class="container">
      <Faq title={c.faqTitle} items={c.faq} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container center">
      <h2>{c.ctaTitle}</h2>
      <p class="mt-3" style="max-width:36rem;margin-inline:auto;">{c.ctaText}</p>
      <div class="mt-4">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{t(locale, 'cta.consultation')}</a>
      </div>
    </div>
  </section>
</Layout>
