---
/**
 * Thank-you page after form submission. Noindex. Purposeful next steps
 * instead of a dead end. NOTE: fires generate_lead context only — the
 * `purchase` event is NOT fired here (it requires verified Stripe payment
 * confirmation, which a thank-you page view does not prove).
 */
import Layout from '../../layouts/Layout.astro';
import { SITE, localePrefix, type Locale } from '../../data/site';
import { t } from '../../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
const p = localePrefix(locale);
const PATH = '/danke/';

const C: Record<Locale, any> = {
  de: {
    metaTitle: 'Danke für Ihre Anfrage | Weissmann AI',
    metaDesc: 'Ihre Anfrage ist bei uns eingegangen. Wir melden uns innerhalb eines Arbeitstags.',
    h1: 'Danke – Ihre Anfrage ist angekommen.',
    text: 'Wir melden uns innerhalb eines Arbeitstags persönlich bei Ihnen. Wenn es eilt, erreichen Sie uns direkt:',
    nextTitle: 'In der Zwischenzeit',
    next: [
      { text: 'Hören Sie, wie der KI-Telefonassistent klingt', href: '/ki-telefonassistent/' },
      { text: 'Sehen Sie unsere transparenten Preise an', href: '/preise/' },
    ],
  },
  en: {
    metaTitle: 'Thank you for your enquiry | Weissmann AI',
    metaDesc: 'Your enquiry has been received. We will get back to you within one business day.',
    h1: 'Thank you — your enquiry has been received.',
    text: 'We’ll get back to you personally within one business day. If it’s urgent, reach us directly:',
    nextTitle: 'In the meantime',
    next: [
      { text: 'Hear what the AI phone agent sounds like', href: '/ki-telefonassistent/' },
      { text: 'Review our transparent pricing', href: '/preise/' },
    ],
  },
  it: {
    metaTitle: 'Grazie per la vostra richiesta | Weissmann AI',
    metaDesc: 'La vostra richiesta è stata ricevuta. Vi risponderemo entro un giorno lavorativo.',
    h1: 'Grazie — la vostra richiesta è stata ricevuta.',
    text: 'Vi risponderemo personalmente entro un giorno lavorativo. Se è urgente, contattateci direttamente:',
    nextTitle: 'Nel frattempo',
    next: [
      { text: 'Ascoltate come suona l’assistente telefonico AI', href: '/ki-telefonassistent/' },
      { text: 'Consultate i nostri prezzi trasparenti', href: '/preise/' },
    ],
  },
  fr: {
    metaTitle: 'Merci pour votre demande | Weissmann AI',
    metaDesc: 'Votre demande a bien été reçue. Nous vous répondrons sous un jour ouvrable.',
    h1: 'Merci — votre demande a bien été reçue.',
    text: 'Nous vous répondrons personnellement sous un jour ouvrable. En cas d’urgence, contactez-nous directement :',
    nextTitle: 'En attendant',
    next: [
      { text: 'Écoutez comment sonne l’agent téléphonique IA', href: '/ki-telefonassistent/' },
      { text: 'Consultez nos tarifs transparents', href: '/preise/' },
    ],
  },
};
const c = C[locale];
---

<Layout locale={locale} path={PATH} title={c.metaTitle} description={c.metaDesc} noindex>
  <section class="section">
    <div class="container" style="max-width:44rem;">
      <h1>{c.h1}</h1>
      <p class="mt-4" style="font-size:var(--fs-500);">{c.text}</p>
      <ul class="checklist mt-3">
        <li><a href={`tel:${SITE.phone}`} data-track="phone_click">{SITE.phoneDisplay}</a></li>
        <li><a href={SITE.whatsapp} rel="noopener" target="_blank" data-track="whatsapp_click">WhatsApp</a></li>
      </ul>
      <h2 class="mt-5" style="font-size:var(--fs-600);">{c.nextTitle}</h2>
      <ul class="checklist">
        {c.next.map((n: any) => <li><a href={`${p}${n.href}`}>{n.text}</a></li>)}
      </ul>
    </div>
  </section>
</Layout>
