---
/**
 * AcademyArticlePage — reusable template for AI Academy pillar + spoke articles
 * (docs/knowledge-hub/). Answer-first hero + TL;DR, entity-rich body, FAQ,
 * commercial cross-links to related services, and (for pillars) the list of
 * cluster spokes. Emits Article + BreadcrumbList + FAQPage schema with named
 * authorship for E-E-A-T. Informational intent — links to services, never sells.
 */
import { SITE, localeUrl, HTML_LANG, type Locale } from '../../data/site';
import { type LocalePaths, pillarHome, urlFor, relFor } from '../../data/routes';
import { type AcademyArticle, type AcademyCluster, clusterPaths, articlePaths, spokesOf } from '../../data/academy';
import { getService, servicePaths } from '../../data/services';
import { matchGlossaryTerms, termPaths } from '../../data/glossary';
import { breadcrumbs, faqPage, CONTENT_DATE } from '../../data/schema';
import { t } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
  localePaths: LocalePaths;
  article: AcademyArticle;
  cluster: AcademyCluster;
}
const { locale, localePaths, article, cluster } = Astro.props;

const LBL: Record<Locale, { short: string; faq: string; inCluster: string; related: string; backToCluster: string; ctaTitle: string; ctaText: string; academy: string; by: string }> = {
  de: { short: 'Kurzantwort', faq: 'Häufige Fragen', inCluster: 'In diesem Themenbereich', related: 'Passende Leistungen', backToCluster: 'Zurück zur Übersicht', ctaTitle: 'Praktische KI für Ihr Unternehmen', ctaText: 'Von der Idee zur Umsetzung – wir zeigen Ihnen, was in Ihrem Fall konkret möglich ist.', academy: 'AI Academy', by: 'Von' },
  en: { short: 'In short', faq: 'Frequently asked questions', inCluster: 'In this topic area', related: 'Relevant services', backToCluster: 'Back to overview', ctaTitle: 'Practical AI for your business', ctaText: 'From idea to implementation – we show you what is concretely possible in your case.', academy: 'AI Academy', by: 'By' },
  it: { short: 'In breve', faq: 'Domande frequenti', inCluster: 'In questa area tematica', related: 'Servizi pertinenti', backToCluster: 'Torna alla panoramica', ctaTitle: 'AI pratica per la vostra azienda', ctaText: 'Dall’idea alla realizzazione: vi mostriamo cosa è concretamente possibile nel vostro caso.', academy: 'AI Academy', by: 'Di' },
  fr: { short: 'En bref', faq: 'Questions fréquentes', inCluster: 'Dans ce domaine', related: 'Services pertinents', backToCluster: 'Retour à l’aperçu', ctaTitle: 'L’IA pratique pour votre entreprise', ctaText: 'De l’idée à la mise en œuvre – nous vous montrons ce qui est concrètement possible dans votre cas.', academy: 'AI Academy', by: 'Par' },
};
const lbl = LBL[locale];
const termsLabel: Record<Locale, string> = { de: 'Begriffe im Glossar', en: 'Key terms in the glossary', it: 'Termini nel glossario', fr: 'Termes du glossaire' };

const pre = locale === 'de' ? '' : `/${locale}`;
const contactHref = `${pre}/kontakt/`;
const academyHub = pillarHome('academy');
const clusterUrl = relFor(locale, clusterPaths(cluster));
const isPillar = article.type === 'pillar';

const spokes = isPillar ? spokesOf(cluster.id) : [];
const relServices = (article.relatedServices ?? [])
  .map((id) => getService(id))
  .filter((s): s is NonNullable<typeof s> => !!s && s.status === 'live');

// Auto-link into the glossary via the article's key entities (entity backbone).
const glossTerms = matchGlossaryTerms(article.keyEntities ?? [], [], 8);

const crumbHome = { de: 'Startseite', en: 'Home', it: 'Home', fr: 'Accueil' }[locale];
const founder = SITE.founders[0]; // Giovanna Carpi
const author = founder.name;
const authorRole = founder.role[locale];
const authorLink = 'linkedin' in founder && founder.linkedin ? founder.linkedin : `${pre}/ueber-uns/`;
const updatedLabel = { de: 'Aktualisiert', en: 'Updated', it: 'Aggiornato', fr: 'Mis à jour' }[locale];
const dateDisplay = new Date(CONTENT_DATE).toLocaleDateString(locale === 'de' ? 'de-CH' : locale, { day: 'numeric', month: 'long', year: 'numeric' });

const crumbItems = [
  { name: crumbHome, path: '/' },
  { name: lbl.academy, path: academyHub[locale] },
  { name: cluster.name[locale], path: clusterPaths(cluster)[locale] },
];
if (!isPillar) crumbItems.push({ name: article.h1[locale], path: localePaths[locale] });

const articleSchema = {
  '@type': 'Article',
  headline: article.h1[locale],
  description: article.metaDescription[locale],
  inLanguage: HTML_LANG[locale],
  datePublished: CONTENT_DATE,
  dateModified: CONTENT_DATE,
  image: `${SITE.domain}/og-default.png`,
  mainEntityOfPage: urlFor(locale, localePaths),
  about: (article.keyEntities ?? []).slice(0, 12),
  author: {
    '@type': 'Person',
    name: author,
    jobTitle: authorRole,
    url: `${SITE.domain}/ueber-uns/`,
    ...('linkedin' in founder && founder.linkedin ? { sameAs: [founder.linkedin] } : {}),
  },
  publisher: { '@id': `${SITE.domain}/#organization` },
  isPartOf: { '@type': 'CollectionPage', name: cluster.name[locale], url: urlFor(locale, clusterPaths(cluster)) },
};
const schema = [
  articleSchema,
  breadcrumbs(locale, crumbItems),
  faqPage(article.faq.map((f) => ({ q: f.q[locale], a: f.a[locale] }))),
];
---
<Layout locale={locale} localePaths={localePaths} title={article.title[locale]} description={article.metaDescription[locale]} schema={schema}>
  <nav class="crumbs container" aria-label="Breadcrumb">
    <a href={`${pre}/`}>{crumbHome}</a><span aria-hidden="true">›</span>
    <a href={relFor(locale, academyHub)}>{lbl.academy}</a><span aria-hidden="true">›</span>
    {isPillar
      ? <span>{cluster.name[locale]}</span>
      : <><a href={clusterUrl}>{cluster.name[locale]}</a><span aria-hidden="true">›</span><span>{article.h1[locale]}</span></>}
  </nav>

  <article class="ac">
    <header class="ac-head container">
      <p class="kicker">{article.kicker[locale]}</p>
      <h1>{article.h1[locale]}</h1>
      <p class="ac-byline">{lbl.by} <a href={authorLink} rel={authorLink.startsWith('http') ? 'noopener' : undefined}>{author}</a>, {authorRole} · Weissmann AI · {updatedLabel} {dateDisplay}</p>
      <aside class="tldr" aria-label={lbl.short}>
        <span class="tldr__label">{lbl.short}</span>
        <p>{article.answerFirst[locale]}</p>
      </aside>
    </header>

    <div class="ac-body container">
      {article.sections.map((s) => (
        <section class="ac-section">
          <h2>{s.heading[locale]}</h2>
          {s.paragraphs?.map((p) => <p>{p[locale]}</p>)}
          {s.bullets && s.bullets.length > 0 && (
            <ul>{s.bullets.map((b) => <li>{b[locale]}</li>)}</ul>
          )}
        </section>
      ))}
    </div>

    {isPillar && spokes.length > 0 && (
      <section class="container ac-spokes">
        <h2>{lbl.inCluster}</h2>
        <div class="ac-spoke-grid">
          {spokes.map((sp) => (
            <a class="ac-spoke" href={relFor(locale, articlePaths(sp))}>
              <h3>{sp.h1[locale]}</h3>
              <p>{sp.answerFirst[locale].slice(0, 130)}…</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="container ac-faq">
      <h2>{lbl.faq}</h2>
      <div class="faq-list">
        {article.faq.map((f) => (
          <details class="faq-item">
            <summary>{f.q[locale]}</summary>
            <p>{f.a[locale]}</p>
          </details>
        ))}
      </div>
    </section>

    {relServices.length > 0 && (
      <section class="container ac-related">
        <h2>{lbl.related}</h2>
        <div class="ac-rel-grid">
          {relServices.map((s) => (
            <a class="ac-rel" href={relFor(locale, servicePaths(s))}>
              <h3>{s.name[locale]}</h3>
              <p>{s.tagline[locale]}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {glossTerms.length > 0 && (
      <section class="container ac-terms">
        <h2>{termsLabel[locale]}</h2>
        <div class="ac-term-chips">
          {glossTerms.map((gt) => <a class="chip" href={relFor(locale, termPaths(gt))}>{gt.term[locale]}</a>)}
        </div>
      </section>
    )}

    {!isPillar && (
      <p class="container ac-back"><a href={clusterUrl}>← {lbl.backToCluster}</a></p>
    )}

    <section class="container ac-cta">
      <h2>{lbl.ctaTitle}</h2>
      <p>{lbl.ctaText}</p>
      <a class="btn btn--primary" href={contactHref} data-track="request_demo">{t(locale, 'nav.cta')}</a>
    </section>
  </article>
</Layout>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; font-size: var(--fs-200); color: var(--ink-mute); padding-top: var(--space-5); flex-wrap: wrap; }
  .crumbs a { color: var(--ink-mute); }
  .crumbs a:hover { color: var(--ink); }
  .ac-head { padding-top: var(--space-5); padding-bottom: var(--space-5); max-width: 52rem; }
  .ac-head h1 { font-size: var(--fs-700); line-height: 1.08; margin: 0.4rem 0 0.6rem; }
  .kicker { text-transform: uppercase; letter-spacing: 0.12em; font-size: var(--fs-200); color: var(--accent); font-weight: 600; }
  .ac-byline { font-size: var(--fs-200); color: var(--ink-mute); margin-bottom: var(--space-4); }
  .tldr { border-left: 3px solid var(--accent); background: color-mix(in srgb, var(--accent) 6%, transparent); border-radius: 0 12px 12px 0; padding: var(--space-4); }
  .tldr__label { text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--fs-200); color: var(--accent); font-weight: 700; }
  .tldr p { margin: 0.4rem 0 0; color: var(--ink); font-size: var(--fs-400); }
  .ac-body { max-width: 52rem; }
  .ac-section { margin-bottom: var(--space-5); }
  .ac-section h2 { font-size: var(--fs-500); margin-bottom: var(--space-3); }
  .ac-section p { color: var(--ink-soft); margin-bottom: var(--space-3); line-height: 1.7; }
  .ac-section ul { display: flex; flex-direction: column; gap: 0.5rem; padding-left: 1.1rem; margin-bottom: var(--space-3); }
  .ac-section li { color: var(--ink-soft); }
  .ac-spokes, .ac-related { padding-top: var(--space-4); padding-bottom: var(--space-4); }
  .ac-spokes > h2, .ac-related > h2, .ac-faq > h2, .ac-cta h2 { font-size: var(--fs-500); margin-bottom: var(--space-4); }
  .ac-spoke-grid, .ac-rel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); gap: var(--space-3); }
  .ac-spoke, .ac-rel { border: 1px solid var(--line); border-radius: 12px; padding: var(--space-4); background: var(--paper); display: block; }
  .ac-spoke:hover, .ac-rel:hover { border-color: var(--accent); text-decoration: none; }
  .ac-spoke h3, .ac-rel h3 { font-size: var(--fs-400); margin: 0 0 0.35rem; color: var(--ink); }
  .ac-spoke p, .ac-rel p { margin: 0; color: var(--ink-soft); font-size: var(--fs-300); }
  .ac-faq { max-width: 52rem; padding-top: var(--space-4); padding-bottom: var(--space-5); }
  .faq-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .faq-item { border: 1px solid var(--line); border-radius: 12px; padding: var(--space-3) var(--space-4); background: var(--paper); }
  .faq-item summary { font-weight: 600; cursor: pointer; }
  .faq-item p { margin: 0.6rem 0 0; color: var(--ink-soft); }
  .ac-terms { max-width: 52rem; padding-top: var(--space-2); padding-bottom: var(--space-4); }
  .ac-terms h2 { font-size: var(--fs-300); text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-mute); margin-bottom: var(--space-3); }
  .ac-term-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .ac-term-chips .chip { border: 1px solid var(--line); border-radius: 999px; padding: 0.3rem 0.85rem; font-size: var(--fs-300); color: var(--ink-soft); }
  .ac-term-chips .chip:hover { border-color: var(--accent); color: var(--ink); text-decoration: none; }
  .ac-back { max-width: 52rem; }
  .ac-back a { color: var(--accent); font-weight: 600; }
  .ac-cta { text-align: center; padding: var(--space-7) var(--space-4); margin-bottom: var(--space-7); border-top: 1px solid var(--line); }
  .ac-cta p { color: var(--ink-soft); max-width: 40rem; margin: 0 auto var(--space-4); }
</style>
