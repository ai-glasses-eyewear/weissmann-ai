---
/**
 * Services hub (/leistungen/, /en/services/, …) — the commercial pillar index.
 * Introduces the 9 fully-separated services grouped Build / Grow / Advise and
 * routes to each dedicated landing page. Registry-driven (services.ts): only
 * `status: 'live'` services link out; upcoming ones show a subtle marker so the
 * hub never ships broken links while pages are built section by section.
 */
import { SITE, localeUrl, type Locale } from '../../data/site';
import { type LocalePaths, urlFor } from '../../data/routes';
import { orderedServices, servicePaths, type ServiceGroup } from '../../data/services';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
  localePaths: LocalePaths;
}
const { locale, localePaths } = Astro.props;

const COPY: Record<Locale, {
  title: string; h1: string; kicker: string; intro: string;
  groups: Record<ServiceGroup, string>; soon: string; view: string;
  crumbHome: string; crumbHere: string; ctaTitle: string; ctaText: string; ctaBtn: string;
}> = {
  de: {
    title: 'KI-Lösungen & Leistungen | Weissmann AI',
    h1: 'Leistungen für Ihr Unternehmen',
    kicker: 'Das Ökosystem',
    intro: 'Jede Leistung ist eine eigenständige Disziplin mit einer eigenen Seite — vom KI-Telefonassistenten über Websites und Sichtbarkeit bis zu Automatisierung und KI-Agenten. Wählen Sie den Baustein, der Sie heute weiterbringt, oder kombinieren Sie mehrere zu einem Wachstumssystem.',
    groups: { build: 'Aufbauen', grow: 'Wachsen', advise: 'Beraten' },
    soon: 'Seite folgt', view: 'Mehr erfahren',
    crumbHome: 'Startseite', crumbHere: 'Leistungen',
    ctaTitle: 'Nicht sicher, wo Sie anfangen sollen?', ctaText: 'In einem kurzen Gespräch finden wir den Baustein mit dem grössten Hebel für Ihr Unternehmen.', ctaBtn: 'Projekt besprechen',
  },
  en: {
    title: 'AI Solutions & Services | Weissmann AI',
    h1: 'Services for your business',
    kicker: 'The ecosystem',
    intro: 'Every service is its own discipline with its own page — from the AI phone assistant through websites and visibility to automation and AI agents. Pick the building block that moves you forward today, or combine several into one growth system.',
    groups: { build: 'Build', grow: 'Grow', advise: 'Advise' },
    soon: 'Coming soon', view: 'Learn more',
    crumbHome: 'Home', crumbHere: 'Services',
    ctaTitle: 'Not sure where to start?', ctaText: 'In a short call we find the building block with the biggest leverage for your business.', ctaBtn: 'Discuss your project',
  },
  it: {
    title: 'Soluzioni e servizi AI | Weissmann AI',
    h1: 'Servizi per la vostra azienda',
    kicker: 'L’ecosistema',
    intro: 'Ogni servizio è una disciplina a sé con la propria pagina — dall’assistente telefonico AI ai siti web e alla visibilità, fino all’automazione e agli agenti AI. Scegliete il tassello che vi fa avanzare oggi, o combinatene più d’uno in un sistema di crescita.',
    groups: { build: 'Costruire', grow: 'Crescere', advise: 'Consigliare' },
    soon: 'In arrivo', view: 'Scopri di più',
    crumbHome: 'Home', crumbHere: 'Servizi',
    ctaTitle: 'Non sapete da dove iniziare?', ctaText: 'In una breve chiamata individuiamo il tassello con la leva maggiore per la vostra azienda.', ctaBtn: 'Parliamo del progetto',
  },
  fr: {
    title: 'Solutions et services IA | Weissmann AI',
    h1: 'Services pour votre entreprise',
    kicker: 'L’écosystème',
    intro: 'Chaque service est une discipline à part entière avec sa propre page — de l’assistant téléphonique IA aux sites web et à la visibilité, jusqu’à l’automatisation et aux agents IA. Choisissez le module qui vous fait avancer aujourd’hui, ou combinez-en plusieurs en un système de croissance.',
    groups: { build: 'Construire', grow: 'Croître', advise: 'Conseiller' },
    soon: 'Bientôt disponible', view: 'En savoir plus',
    crumbHome: 'Accueil', crumbHere: 'Services',
    ctaTitle: 'Vous ne savez pas par où commencer ?', ctaText: 'En un court appel, nous identifions le module au plus fort levier pour votre entreprise.', ctaBtn: 'Discuter du projet',
  },
};
const c = COPY[locale];

const services = orderedServices();
const groupsOrder: ServiceGroup[] = ['build', 'grow', 'advise'];

const homeUrl = `${localeUrl(locale, '/').replace(SITE.domain, '')}`;
const contactPath = locale === 'de' ? '/kontakt/' : `/${locale}/kontakt/`;

const schema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: c.crumbHome, item: localeUrl(locale, '/') },
      { '@type': 'ListItem', position: 2, name: c.crumbHere, item: urlFor(locale, localePaths) },
    ],
  },
  {
    '@type': 'CollectionPage',
    name: c.h1,
    url: urlFor(locale, localePaths),
    isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.domain },
    about: services.map((s) => ({ '@type': 'Service', name: s.name[locale], serviceType: s.serviceType })),
  },
];
---
<Layout locale={locale} localePaths={localePaths} title={c.title} description={c.intro} schema={schema}>
  <nav class="crumbs container" aria-label="Breadcrumb">
    <a href={homeUrl}>{c.crumbHome}</a><span aria-hidden="true">›</span><span>{c.crumbHere}</span>
  </nav>

  <header class="hub-head container">
    <p class="kicker">{c.kicker}</p>
    <h1>{c.h1}</h1>
    <p class="hub-intro">{c.intro}</p>
  </header>

  <div class="container hub-groups">
    {groupsOrder.map((g) => (
      <section class="hub-group">
        <h2>{c.groups[g]}</h2>
        <div class="hub-grid">
          {services.filter((s) => s.group === g).map((s) => {
            const live = s.status === 'live';
            const href = urlFor(locale, servicePaths(s)).replace(SITE.domain, '');
            return (
              <article class={`svc-card${live ? '' : ' svc-card--soon'}`}>
                <h3>{s.name[locale]}</h3>
                <p>{s.tagline[locale]}</p>
                {live
                  ? <a class="svc-card__link" href={href}>{c.view} →</a>
                  : <span class="svc-card__soon">{c.soon}</span>}
              </article>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <section class="container hub-cta">
    <h2>{c.ctaTitle}</h2>
    <p>{c.ctaText}</p>
    <a class="btn btn--primary" href={contactPath} data-track="request_demo">{c.ctaBtn}</a>
  </section>
</Layout>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; font-size: var(--fs-200); color: var(--ink-mute); padding-top: var(--space-5); }
  .crumbs a { color: var(--ink-mute); }
  .crumbs a:hover { color: var(--ink); }
  .hub-head { padding-top: var(--space-5); padding-bottom: var(--space-5); max-width: 60rem; }
  .hub-head h1 { font-size: var(--fs-700); line-height: 1.05; margin: 0.4rem 0 1rem; }
  .kicker { text-transform: uppercase; letter-spacing: 0.12em; font-size: var(--fs-200); color: var(--accent); font-weight: 600; }
  .hub-intro { font-size: var(--fs-400); color: var(--ink-soft); max-width: 52rem; }
  .hub-groups { display: flex; flex-direction: column; gap: var(--space-6); padding-bottom: var(--space-7); }
  .hub-group > h2 { font-size: var(--fs-300); text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-mute); margin-bottom: var(--space-4); border-bottom: 1px solid var(--line); padding-bottom: 0.6rem; }
  .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: var(--space-4); }
  .svc-card { border: 1px solid var(--line); border-radius: 14px; padding: var(--space-4); background: var(--paper); display: flex; flex-direction: column; gap: 0.6rem; }
  .svc-card h3 { font-size: var(--fs-500); margin: 0; }
  .svc-card p { color: var(--ink-soft); font-size: var(--fs-300); margin: 0; flex: 1; }
  .svc-card__link { font-weight: 600; color: var(--accent); }
  .svc-card--soon { opacity: 0.72; }
  .svc-card__soon { font-size: var(--fs-200); text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-mute); border: 1px solid var(--line); border-radius: 999px; padding: 0.2rem 0.7rem; align-self: flex-start; }
  .hub-cta { text-align: center; padding: var(--space-7) var(--space-4); margin-bottom: var(--space-7); border-top: 1px solid var(--line); }
  .hub-cta h2 { font-size: var(--fs-600); margin-bottom: 0.6rem; }
  .hub-cta p { color: var(--ink-soft); max-width: 40rem; margin: 0 auto var(--space-4); }
</style>
