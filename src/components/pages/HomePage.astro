const c = C[locale];
const videoSrc = locale === 'de' ? '/videos/weissmann-demo-de.mp4' : '/videos/weissmann-demo-en.mp4';

const schema = [
  organization(locale),
  webSite(locale),
  webPage(locale, '/', c.metaTitle, c.metaDesc),
  faqPage(c.faq),
];

const phoneStarter = getPackage('phone-starter');
const phonePremium = getPackage('phone-premium');
const websiteStarter = getPackage('website-starter');
---

<Layout locale={locale} path="/" title={c.metaTitle} description={c.metaDesc} schema={schema}>
  <!-- Hero -->
  <section class="section hero">
    <div class="container">
      <span class="eyebrow">{c.heroEyebrow}</span>
      <h1>{c.heroTitle}</h1>
      <p class="hero__text">{c.heroText}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href="#demo" data-track="demo_play">{c.heroSecondary}</a>
      </div>
    </div>
  </section>

  <!-- Demo -->
  <section class="section section--alt" id="demo">
    <div class="container">
      <div class="section-head">
        <h2>{c.demoTitle}</h2>
        <p>{c.demoText}</p>
      </div>
      <video controls preload="metadata" class="demo-video" data-demo-video>
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </section>

  <!-- Service ecosystem -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.ecosystemEyebrow}</span>
        <h2>{c.ecosystemTitle}</h2>
        <p>{c.ecosystemText}</p>
      </div>
      <div class="grid grid--3">
        {c.services.map((s: any) => (
          <a class="card service-card" href={`${p}${s.href}`} data-track="service_view">
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <span class="service-card__more">{t(locale, 'cta.learnMore')} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Method -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.methodEyebrow}</span>
        <h2>{c.methodTitle}</h2>
        <p>{c.methodText}</p>
      </div>
      <MethodTimeline locale={locale} />
    </div>
  </section>

  <!-- Calculator -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">{c.calcEyebrow}</span>
      <MissedCallsCalculator locale={locale} />
    </div>
  </section>

  <!-- Pricing preview -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.pricingEyebrow}</span>
        <h2>{c.pricingTitle}</h2>
        <p>{c.pricingText}</p>
      </div>
      <div class="grid grid--3">
        <PricingCard pkg={phoneStarter} locale={locale} />
        <PricingCard pkg={phonePremium} locale={locale} highlight />
        <PricingCard pkg={websiteStarter} locale={locale} />
      </div>
      <p class="center mt-4">
        <a class="btn btn--ghost" href={`${p}/preise/`} data-track="pricing_view">{t(locale, 'cta.allPricing')} →</a>
      </p>
      <p class="center muted">{t(locale, 'price.vatNote')}</p>
    </div>
  </section>

  <!-- Trust -->
  <section class="section">
    <div class="container">
      <div class="section-head"><h2>{c.trustTitle}</h2></div>
      <div class="grid grid--4">
        {c.trust.map((item: any) => (
          <div class="card">
            <h3>{item.title}</h3>
            <p class="mt-3">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <Faq title={c.faqTitle} items={c.faq} />
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section">
    <div class="container center">
      <h2>{c.finalTitle}</h2>
      <p class="mt-3 hero__text" style="margin-inline:auto;">{c.finalText}</p>
      <div class="hero__actions" style="justify-content:center;">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href={`tel:+41783459788`} data-track="phone_click">{t(locale, 'cta.call')}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero { padding-block: var(--space-7) var(--space-6); }
  .hero h1 { max-width: 46rem; }
  .hero__text { max-width: 40rem; margin-top: var(--space-4); font-size: var(--fs-500); }
  .hero__actions { display: flex; gap: var(--space-3); margin-top: var(--space-5); flex-wrap: wrap; }
  .demo-video {
    width: 100%;
    max-width: 52rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    background: var(--ink);
  }
  .service-card { color: inherit; display: flex; flex-direction: column; }
  .service-card:hover { text-decoration: none; border-color: var(--accent); }
  .service-card p { margin-top: var(--space-2); font-size: var(--fs-300); }
  .service-card__more { margin-top: auto; padding-top: var(--space-3); color: var(--accent); font-weight: 600; font-size: var(--fs-300); }
</style>

<script is:inline>
  // demo_play / demo_complete tracking on the hero video
  (function () {
    var v = document.querySelector('[data-demo-video]');
    if (!v) return;
    var played = false;
    v.addEventListener('play', function () {
      if (played) return;
      played = true;
      if (window.wmEvent) window.wmEvent('demo_play', { demo: 'homepage_video' });
    });
    v.addEventListener('ended', function () {
      if (window.wmEvent) window.wmEvent('demo_complete', { demo: 'homepage_video' });
    });
  })();
</script>
