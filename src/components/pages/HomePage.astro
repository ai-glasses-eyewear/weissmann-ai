const c = C[locale];
const videoSrc = locale === 'de' ? '/videos/weissmann-demo-de.mp4' : '/videos/weissmann-demo-en.mp4';

const schema = [
  organization(locale),
  webSite(locale),
  webPage(locale, '/', c.metaTitle, c.metaDesc),
  faqPage(c.faq),
];

const phoneStarter = getPackage('phone-starter');
const phonePremium = getPackage('phone-premium');
const websiteStarter = getPackage('website-starter');
---

<Layout locale={locale} path="/" title={c.metaTitle} description={c.metaDesc} schema={schema}>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__content">
      <span class="eyebrow">{c.heroEyebrow}</span>
      <h1 class="hero__title">{c.heroTitle}</h1>
      <p class="hero__text">{c.heroText}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href="#system">{c.heroSecondary}</a>
      </div>
      <div class="hero__wave" aria-hidden="true">
        {Array.from({ length: 36 }, (_, i) => (
          <span class="hero__bar" style={`--i:${i}; --h:${[18, 34, 52, 70, 84, 62, 40, 26][i % 8]}%`}></span>
        ))}
      </div>
      <p class="hero__trust">
        <span>24/7</span>
        <span class="hero__dot"></span>
        <span>DE · EN · FR · IT</span>
        <span class="hero__dot"></span>
        <span>Zürich, {locale === 'de' ? 'Schweiz' : locale === 'it' ? 'Svizzera' : locale === 'fr' ? 'Suisse' : 'Switzerland'}</span>
      </p>
    </div>
  </section>

  <!-- ── Growth system: editorial numbered flow ───────────── -->
  <section class="section section--alt" id="system">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.systemEyebrow}</span>
        <h2>{c.systemTitle}</h2>
        <p>{c.systemText}</p>
      </div>
      <ol class="system">
        {c.system.map((s: any) => (
          <li class="system__row">
            <span class="system__num" aria-hidden="true">{s.n}</span>
            <div class="system__body">
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
            <a class="system__link" href={`${p}${s.href}`} data-track="service_view">
              {s.label} <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Method ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.methodEyebrow}</span>
        <h2>{c.methodTitle}</h2>
        <p>{c.methodText}</p>
      </div>
      <MethodTimeline locale={locale} />
    </div>
  </section>

  <!-- ── Voice proof ──────────────────────────────────────── -->
  <section class="section section--alt" id="demo">
    <div class="container voice">
      <div class="voice__copy">
        <span class="eyebrow">{c.voiceEyebrow}</span>
        <h2>{c.voiceTitle}</h2>
        <p class="mt-3">{c.voiceText}</p>
        <p class="mt-4">
          <a class="btn btn--secondary" href={`${p}/ki-telefonassistent/`}>{c.voiceCta}</a>
        </p>
      </div>
      <video controls preload="metadata" class="demo-video" data-demo-video>
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </section>

  <!-- ── Calculator ───────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">{c.calcEyebrow}</span>
      <MissedCallsCalculator locale={locale} />
    </div>
  </section>

  <!-- ── Pricing preview ──────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.pricingEyebrow}</span>
        <h2>{c.pricingTitle}</h2>
        <p>{c.pricingText}</p>
      </div>
      <div class="grid grid--3">
        <PricingCard pkg={phoneStarter} locale={locale} />
        <PricingCard pkg={phonePremium} locale={locale} highlight />
        <PricingCard pkg={websiteStarter} locale={locale} />
      </div>
      <p class="center mt-4">
        <a class="btn btn--ghost" href={`${p}/preise/`} data-track="pricing_view">{t(locale, 'cta.allPricing')} →</a>
      </p>
      <p class="center muted">{t(locale, 'price.vatNote')}</p>
    </div>
  </section>

  <!-- ── Why us: editorial statements ─────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head"><h2>{c.trustTitle}</h2></div>
      <dl class="why">
        {c.trust.map((item: any) => (
          <div class="why__item">
            <dt>{item.title}</dt>
            <dd>{item.text}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <Faq title={c.faqTitle} items={c.faq} />
    </div>
  </section>

  <!-- ── Final CTA ────────────────────────────────────────── -->
  <section class="section final-cta">
    <div class="container center">
      <h2 style="max-width:26ch;margin-inline:auto;">{c.finalTitle}</h2>
      <p class="mt-3" style="max-width:38rem;margin-inline:auto;color:var(--ink-mute);">{c.finalText}</p>
      <div class="hero__actions" style="justify-content:center;">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href="tel:+41783459788" data-track="phone_click">{t(locale, 'cta.call')}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(5.5rem, 14vh, 9.5rem) var(--space-6);
  }
  .hero__glow {
    position: absolute;
    inset: -20% -10% auto;
    height: 75%;
    background:
      radial-gradient(42% 55% at 68% 18%, rgba(157 0 255 / 0.17), transparent 70%),
      radial-gradient(30% 40% at 22% 8%, rgba(157 0 255 / 0.09), transparent 70%);
    pointer-events: none;
  }
  .hero__content { position: relative; }
  .hero__title {
    max-width: 16ch;
    background: linear-gradient(135deg, #ffffff 55%, #cba3f2 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__text {
    max-width: 40rem;
    margin-top: var(--space-4);
    font-size: var(--fs-500);
    color: var(--ink-mute);
    line-height: 1.75;
  }
  .hero__actions { display: flex; gap: var(--space-3); margin-top: var(--space-5); flex-wrap: wrap; }

  .hero__wave {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 64px;
    margin-top: var(--space-6);
    max-width: 34rem;
    mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
  }
  .hero__bar {
    flex: 1;
    height: var(--h);
    min-height: 6px;
    border-radius: 99px;
    background: linear-gradient(180deg, var(--accent-bright), var(--accent));
    opacity: 0.85;
    animation: wave 1.9s ease-in-out calc(var(--i) * -0.11s) infinite alternate;
    transform-origin: center;
  }
  @keyframes wave {
    from { transform: scaleY(0.45); opacity: 0.5; }
    to   { transform: scaleY(1);    opacity: 0.95; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__bar { animation: none; }
  }
  .hero__trust {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
    font-size: var(--fs-300);
    color: var(--ink-mute);
    letter-spacing: 0.04em;
  }
  .hero__dot { width: 3px; height: 3px; border-radius: 50%; background: var(--line); }

  /* ── Growth system rows ───────────────────────────────── */
  .system {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .system__row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3) var(--space-4);
    align-items: start;
    padding-block: var(--space-4);
    border-top: 1px solid var(--line-soft);
  }
  .system__row:last-child { border-bottom: 1px solid var(--line-soft); }
  .system__num {
    font-size: clamp(1.7rem, 3.5vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(194 107 255 / 0.5);
    padding-top: 0.2rem;
    min-width: 3.2rem;
  }
  .system__body h3 { font-size: var(--fs-700); }
  .system__body p {
    margin-top: var(--space-2);
    max-width: 52rem;
    color: var(--ink-mute);
  }
  .system__link {
    grid-column: 2;
    justify-self: start;
    font-weight: 600;
    font-size: var(--fs-300);
    color: var(--accent-bright);
  }
  @media (min-width: 920px) {
    .system__row { grid-template-columns: 6rem 1fr auto; }
    .system__link { grid-column: auto; align-self: center; }
  }

  /* ── Voice proof ──────────────────────────────────────── */
  .voice {
    display: grid;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 920px) {
    .voice { grid-template-columns: 1fr 1.15fr; }
  }
  .demo-video {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line-soft);
    box-shadow: var(--glow);
    background: #000;
  }

  /* ── Why us ───────────────────────────────────────────── */
  .why {
    display: grid;
    gap: 0;
    margin: 0;
  }
  @media (min-width: 760px) {
    .why { grid-template-columns: 1fr 1fr; column-gap: var(--space-6); }
  }
  .why__item {
    padding-block: var(--space-4);
    border-top: 1px solid var(--line-soft);
  }
  .why__item dt {
    font-weight: 600;
    color: var(--ink);
    font-size: var(--fs-600);
    letter-spacing: -0.015em;
  }
  .why__item dd {
    margin: var(--space-2) 0 0;
    color: var(--ink-mute);
  }

  .final-cta { padding-block: var(--space-7); }
</style>

<script is:inline>
  // demo_play / demo_complete tracking on the voice video
  (function () {
    var v = document.querySelector('[data-demo-video]');
    if (!v) return;
    var played = false;
    v.addEventListener('play', function () {
      if (played) return;
      played = true;
      if (window.wmEvent) window.wmEvent('demo_play', { demo: 'homepage_video' });
    });
    v.addEventListener('ended', function () {
      if (window.wmEvent) window.wmEvent('demo_complete', { demo: 'homepage_video' });
    });
  })();
</script>
