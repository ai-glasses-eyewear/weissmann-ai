const c = C[locale];
const videoSrc = locale === 'de' ? '/videos/weissmann-demo-de.mp4' : '/videos/weissmann-demo-en.mp4';
const posterSrc = theme === 'b' ? '/poster-call-dark.png' : '/poster-call-light.png';

const schema = [
  organization(locale),
  webSite(locale),
  webPage(locale, '/', c.metaTitle, c.metaDesc),
  faqPage(c.faq),
];

const phoneStarter = getPackage('phone-starter');
const phonePremium = getPackage('phone-premium');
const websiteStarter = getPackage('website-starter');
---

<Layout locale={locale} path="/" title={c.metaTitle} description={c.metaDesc} schema={schema}>
  <!-- ── 2. Hero ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <span class="eyebrow">{c.heroEyebrow}</span>
      <h1 class="hero__title">{c.heroTitle}</h1>
      <p class="hero__text">{c.heroText}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href="#system">{c.heroSecondary}</a>
      </div>
    </div>
  </section>

  <!-- ── 3. Strategic trust statement ─────────────────────── -->
  <section class="section--tight truststrip">
    <div class="container">
      <p class="truststrip__statement">{c.trustStatement}</p>
      <ul class="truststrip__facts">
        {c.trustFacts.map((f: string) => <li>{f}</li>)}
      </ul>
    </div>
  </section>

  <!-- ── 4. Six modules — one system ──────────────────────── -->
  <section class="section" id="system">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.systemEyebrow}</span>
        <h2>{c.systemTitle}</h2>
        <p>{c.systemText}</p>
      </div>

      <p class="growthwords" aria-label={c.systemEyebrow}>
        {c.growthWords.map((w: string, i: number) => (
          <>
            <span class="growthwords__word">{w}</span>
            {i < c.growthWords.length - 1 && <span class="growthwords__sep" aria-hidden="true">→</span>}
          </>
        ))}
      </p>

      <ol class="system">
        {c.system.map((s: any) => (
          <li class="system__row">
            <span class="system__num" aria-hidden="true">{s.n}</span>
            <div class="system__body">
              <h3><a href={`${p}${s.href}`} data-track="service_view">{s.title}</a></h3>
              <p>{s.text}</p>
            </div>
            <a class="system__link" href={`${p}${s.href}`} data-track="service_view" aria-label={s.title}>→</a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── 5. Method ────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.methodEyebrow}</span>
        <h2>{c.methodTitle}</h2>
        <p>{c.methodText}</p>
      </div>
      <MethodTimeline locale={locale} />
    </div>
  </section>

  <!-- ── 6+7. Implementation proof: voice demo ────────────── -->
  <section class={`section voice-section ${theme === 'b' ? 'section--dark' : ''}`} id="demo">
    <div class="container voice">
      <div>
        <span class="eyebrow">{c.voiceEyebrow}</span>
        <h2>{c.voiceTitle}</h2>
        <p class="mt-3 voice__text">{c.voiceText}</p>
        <p class="mt-4">
          <a class="btn btn--secondary" href={`${p}/ki-telefonassistent/`}>{c.voiceCta}</a>
        </p>
      </div>
      <video controls preload="none" poster={posterSrc} class="demo-video" data-demo-video>
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </section>

  <!-- ── Calculator (interactive proof) ───────────────────── -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">{c.calcEyebrow}</span>
      <MissedCallsCalculator locale={locale} />
    </div>
  </section>

  <!-- ── 9. Why Weissmann — numbered editorial index ──────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head"><h2>{c.whyTitle}</h2></div>
      <ol class="why">
        {c.why.map((item: string, i: number) => (
          <li class="why__item">
            <span class="why__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── 11. Pricing overview ─────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.pricingEyebrow}</span>
        <h2>{c.pricingTitle}</h2>
        <p>{c.pricingText}</p>
      </div>
      <div class="grid grid--3">
        <PricingCard pkg={phoneStarter} locale={locale} />
        <PricingCard pkg={phonePremium} locale={locale} highlight />
        <PricingCard pkg={websiteStarter} locale={locale} />
      </div>
      <p class="center mt-4">
        <a class="btn btn--ghost" href={`${p}/preise/`} data-track="pricing_view">{t(locale, 'cta.allPricing')} →</a>
      </p>
      <p class="center muted">{t(locale, 'price.vatNote')}</p>
    </div>
  </section>

  <!-- ── 13. FAQ ──────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <Faq title={c.faqTitle} items={c.faq} />
    </div>
  </section>

  <!-- ── 14. Final CTA — selective dark moment ────────────── -->
  <section class="section section--dark final-cta">
    <div class="container center">
      <h2 style="max-width:26ch;margin-inline:auto;">{c.finalTitle}</h2>
      <p class="mt-3" style="max-width:38rem;margin-inline:auto;">{c.finalText}</p>
      <div class="hero__actions" style="justify-content:center;">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href="tel:+41783459788" data-track="phone_click">{t(locale, 'cta.call')}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero: typographic, no effects ────────────────────── */
  .hero { padding-block: clamp(4.5rem, 12vh, 8rem) var(--space-6); }
  .hero__title { max-width: 18ch; }
  .hero__text {
    max-width: 38rem;
    margin-top: var(--space-4);
    font-size: var(--fs-500);
    color: var(--ink-mute);
    line-height: 1.7;
  }
  .hero__actions { display: flex; gap: var(--space-3); margin-top: var(--space-5); flex-wrap: wrap; }

  /* ── Trust strip ──────────────────────────────────────── */
  .truststrip {
    border-block: 1px solid var(--line);
    padding-block: var(--space-4);
  }
  .truststrip .container {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    align-items: baseline;
    justify-content: space-between;
  }
  .truststrip__statement {
    font-size: var(--fs-500);
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .truststrip__facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--fs-300);
    color: var(--ink-mute);
  }

  /* ── Growth words progression ─────────────────────────── */
  .growthwords {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.85rem;
    margin-bottom: var(--space-5);
    font-size: var(--fs-300);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .growthwords__sep { color: var(--accent); font-weight: 400; }

  /* ── System index rows ────────────────────────────────── */
  .system { list-style: none; margin: 0; padding: 0; }
  .system__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: baseline;
    padding-block: var(--space-4);
    border-top: 1px solid var(--line);
  }
  .system__row:last-child { border-bottom: 1px solid var(--line); }
  .system__num {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--accent);
    font-size: var(--fs-300);
    letter-spacing: 0.05em;
    min-width: 2.2rem;
  }
  .system__body { display: flex; flex-wrap: wrap; gap: 0.35rem var(--space-4); align-items: baseline; }
  .system__body h3 { font-size: var(--fs-700); }
  .system__body h3 a { color: var(--ink); }
  .system__body h3 a:hover { text-decoration: none; color: var(--accent); }
  .system__body p { color: var(--ink-mute); font-size: var(--fs-400); }
  .system__link {
    font-size: var(--fs-600);
    color: var(--ink);
    transition: transform 0.15s ease, color 0.15s ease;
  }
  .system__link:hover { color: var(--accent); text-decoration: none; transform: translateX(3px); }
  @media (min-width: 920px) {
    .system__body { flex-wrap: nowrap; }
    .system__body h3 { min-width: 15rem; }
  }

  /* ── Voice section ────────────────────────────────────── */
  .voice {
    display: grid;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 920px) {
    .voice { grid-template-columns: 1fr 1.15fr; }
  }
  .voice__text { max-width: 34rem; }
  .voice-section:not(.section--dark) { background: var(--paper-soft); }
  .voice-section.section--dark .voice__text { color: var(--dark-mute); }
  .demo-video {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: #000;
  }
  .voice-section.section--dark .demo-video { border-color: var(--dark-line); }

  /* ── Why index ────────────────────────────────────────── */
  .why { list-style: none; margin: 0; padding: 0; display: grid; }
  @media (min-width: 760px) {
    .why { grid-template-columns: 1fr 1fr; column-gap: var(--space-6); }
  }
  .why__item {
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    padding-block: var(--space-3);
    border-top: 1px solid var(--line);
  }
  .why__item p {
    font-size: var(--fs-600);
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.012em;
  }
  .why__num {
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-300);
    font-weight: 600;
    color: var(--accent);
    min-width: 1.8rem;
  }

  .final-cta { padding-block: var(--space-7); }
</style>

<script is:inline>
  // demo_play / demo_complete tracking on the voice video
  (function () {
    var v = document.querySelector('[data-demo-video]');
    if (!v) return;
    var played = false;
    v.addEventListener('play', function () {
      if (played) return;
      played = true;
      if (window.wmEvent) window.wmEvent('demo_play', { demo: 'homepage_video' });
    });
    v.addEventListener('ended', function () {
      if (window.wmEvent) window.wmEvent('demo_complete', { demo: 'homepage_video' });
    });
  })();
</script>
