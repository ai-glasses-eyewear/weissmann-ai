      { n: '01', title: 'Site web', text: 'La fondation digitale.', href: '/leistungen/ai-websites/' },
      { n: '02', title: 'SEO & GEO', text: 'Visibilité dans les moteurs de recherche et les réponses IA.', href: '/preise/' },
      { n: '03', title: 'Google Ads', text: 'Demande ciblée et trafic qualifié.', href: '/preise/' },
      { n: '04', title: 'Agents IA', text: 'Répondre à chaque demande et la qualifier.', href: '/ki-telefonassistent/' },
      { n: '05', title: 'Automatisation', text: 'Exécuter intelligemment le travail récurrent.', href: '/kontakt/' },
      { n: '06', title: 'Mesure', text: 'Comprendre les résultats et s’améliorer en continu.', href: '/kontakt/' },
    ],
    methodEyebrow: 'La Méthode Weissmann AI',
    methodTitle: 'Systématique, pas aléatoire',
    methodText: 'Sept étapes de l’analyse à l’optimisation continue — transparentes et accompagnées personnellement.',
    voiceEyebrow: 'De la mise en œuvre, pas de la théorie',
    voiceTitle: 'Voici comment sonne l’IA implémentée.',
    voiceText:
      'L’agent téléphonique Weissmann AI en conditions réelles : voix naturelle, vraie réservation de rendez-vous, transfert humain quand cela compte. Un composant du système — écoutez-le ici.',
    voiceCta: 'L’agent téléphonique IA',
    calcEyebrow: 'Calculer plutôt que deviner',
    pricingEyebrow: 'Tarifs transparents',
    pricingTitle: 'Des forfaits clairement définis. Pas de coûts cachés.',
    pricingText: 'De l’agent téléphonique IA au site web complet — des prix fixes équitables au périmètre clairement défini.',
    whyTitle: 'Pourquoi Weissmann',
    why: [
      'Un partenaire pour tout le système.',
      'Stratégie et mise en œuvre d’une seule source.',
      'L’IA avec un objectif business clair.',
      'Multilingue pour le marché suisse.',
      'Mesurable, modulaire et optimisé en continu.',
      'Un accompagnement personnel — pas de plateforme self-service anonyme.',
    ],
    faqTitle: 'Questions fréquentes',
    faq: [
      { q: 'Qu’est-ce qui distingue Weissmann AI d’une agence classique ?', a: 'Nous ne livrons pas seulement du conseil ou des mesures isolées : nous implémentons un système cohérent (site, visibilité, agents IA, automatisation et mesure) et l’accompagnons personnellement en exploitation. Chaque mesure a un indicateur.' },
      { q: 'Dois-je acheter tout le système ?', a: 'Non. Les services sont modulaires. Les entreprises peuvent commencer par un seul domaine et ajouter d’autres composants plus tard. Le plus grand avantage stratégique naît toutefois quand plusieurs services travaillent ensemble.' },
      { q: 'À quelles entreprises le système convient-il ?', a: 'Restaurants, cabinets médicaux, salons, immobilier, assurances, commerce et PME qui perdent des demandes, dont le site ne convertit pas, ou qui veulent automatiser le travail routinier.' },
      { q: 'Comment démarre un projet ?', a: 'Par un premier entretien sans engagement. Nous analysons ensuite votre situation et proposons concrètement quel composant crée de l’impact en premier — périmètre, prix et calendrier inclus.' },
      { q: 'Weissmann peut-il intégrer des systèmes existants ?', a: 'Quand c’est techniquement possible, oui — par exemple des systèmes de réservation ou de gestion existants. Nous évaluons honnêtement ce qui est intégrable dans votre cas lors du premier entretien, avant votre décision.' },
      { q: 'Tous les services sont-ils disponibles individuellement ?', a: 'Oui. Site web, SEO, GEO, Google Ads, agent téléphonique IA et automatisation se réservent individuellement — avec un périmètre et un prix clairement définis.' },
      { q: 'Comment le succès est-il mesuré ?', a: 'Avec Google Analytics 4 correctement configuré et le suivi des conversions : appels, demandes, réservations et achats deviennent mesurables. Vous recevez des rapports compréhensibles plutôt que des impressions.' },
    ],
    finalTitle: 'Prêt pour un système dont vous pouvez mesurer l’impact ?',
    finalText: 'Réservez un premier entretien sans engagement. Nous vous montrons concrètement où l’IA et l’automatisation créent de l’impact dans votre entreprise — et où pas (encore).',
    glasses: {
      eyebrow: 'L’écosystème Weissmann AI',
      title: 'Lunettes intelligentes IA pour le travail',
      lead: 'Au-delà de l’IA au téléphone, Weissmann amène l’IA dans votre champ de vision. Les lunettes connectées Even Realities offrent traduction en direct, sous-titres en direct et un assistant IA discret – conçus pour les réunions, l’accessibilité et le business international.',
      features: [
        { label: 'Traduction en direct', text: 'Comprenez les conversations en temps réel, au-delà des barrières linguistiques.' },
        { label: 'Sous-titres en direct', text: 'Chaque mot en texte dans votre champ de vision – même dans le bruit.' },
        { label: 'Assistant IA', text: 'Réponses, notes et rappels sans sortir votre téléphone.' },
        { label: 'Réunions', text: 'Résumés et points clés tout en restant pleinement présent.' },
        { label: 'Accessibilité', text: 'Sous-titres et traduction facilitent l’écoute et la compréhension.' },
        { label: 'Business international', text: 'Négociez et présentez en toute confiance dans chaque langue.' },
        { label: 'Productivité', text: 'Moins de distraction, plus de concentration – l’info au bon moment.' },
      ],
      ctaLabel: 'Découvrir les lunettes intelligentes IA sur AI-Eyewear',
    },
  },
};

const c = C[locale];
const videoSrc = locale === 'de' ? '/videos/weissmann-demo-de.mp4' : '/videos/weissmann-demo-en.mp4';
const posterSrc = theme === 'b' ? '/poster-call-dark.png' : '/poster-call-light.png';

// Organization + WebSite are emitted site-wide by the Layout; the homepage adds
// its WebPage + FAQ.
const schema = [
  webPage(locale, '/', c.metaTitle, c.metaDesc),
  faqPage(c.faq),
];

const phoneStarter = getPackage('phone-starter');
const phonePremium = getPackage('phone-premium');
const websiteStarter = getPackage('website-starter');
---

<Layout locale={locale} path="/" title={c.metaTitle} description={c.metaDesc} schema={schema}>
  <!-- ── 2. Hero — premium dark, animated phone device ─────── -->
  <section class="hero hero--dark">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="eyebrow eyebrow--light">{c.heroEyebrow}</span>
        <h1 class="hero__title">{c.heroTitle}</h1>
        <p class="hero__text">{c.heroText}</p>
        <div class="hero__actions">
          <a class="btn btn--accent" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
          <a class="btn btn--ondark" href="#demo" data-track="demo_scroll">{c.heroSecondary}</a>
        </div>
        <ul class="hero__chips">
          {heroChips.map((chip: string) => <li><Icon name="check" size={15} />{chip}</li>)}
        </ul>
      </div>
      <div class="hero__visual" aria-hidden="true">
        <div class="device">
          <span class="device__notch"></span>
          <figure class="callcard">
            <figcaption class="callcard__bar">
              <span class="callcard__live"><span class="callcard__pulse"></span>{c.mock.status}</span>
              <span class="callcard__time">00:12</span>
            </figcaption>
            <div class="callcard__thread">
              <p class="bubble bubble--caller">{c.mock.caller}</p>
              <p class="bubble bubble--ai">{c.mock.ai}</p>
              <div class="callcard__wave"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
            </div>
            <div class="callcard__foot">
              <span class="callcard__badge"><Icon name="calendar-check" size={17} /></span>
              <span>{c.mock.booked}</span>
            </div>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Live click-to-call: talk to the real AI now ──────── -->
  <section class="section livecall">
    <div class="container">
      <div class="livecall__inner reveal">
        <span class="livecall__pulse" aria-hidden="true"><Icon name="phone" size={24} /></span>
        <span class="eyebrow">{lc.eyebrow}</span>
        <h2>{lc.title}</h2>
        <p class="livecall__text">{lc.text}</p>
        <a class="btn btn--accent livecall__cta" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live">
          <Icon name="phone" size={20} />{lc.cta} · {SITE.aiPhoneDisplay}
        </a>
        <p class="livecall__hint"><strong>{lc.hintLabel}</strong> {lc.hint}</p>
        <p class="livecall__note">{lc.note}</p>
      </div>
    </div>
  </section>

  <!-- ── 3. Strategic trust statement ─────────────────────── -->
  <section class="section--tight truststrip">
    <div class="container">
      <p class="truststrip__statement">{c.trustStatement}</p>
      <ul class="truststrip__facts">
        {c.trustFacts.map((f: string, i: number) => <li><Icon name={TRUST_ICONS[i]} size={16} />{f}</li>)}
      </ul>
    </div>
  </section>

  <!-- ── How the AI phone agent works — 4-step call flow ──── -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{flow.eyebrow}</span>
        <h2>{flow.title}</h2>
        <p>{flow.text}</p>
      </div>
      <ol class="callflow">
        {flow.steps.map((s, i) => (
          <li class="callflow__step reveal" style={`--i:${i}`}>
            <span class="callflow__icon"><Icon name={FLOW_ICONS[i]} size={22} /></span>
            <span class="callflow__n">{String(i + 1).padStart(2, '0')}</span>
            <h3>{s.label}</h3>
            <p>{s.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Try it for your industry (ties to the live call) ──── -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{scen.eyebrow}</span>
        <h2>{scen.title}</h2>
        <p>{scen.text}</p>
      </div>
      <div class="scenarios">
        {scen.items.map((it, i) => (
          <div class="scenario reveal" style={`--i:${i}`}>
            <div class="scenario__name"><span class="feat-icon"><Icon name={SCENARIO_ICONS[i]} size={20} /></span>{it.name}</div>
            <p class="scenario__does">{it.does}</p>
            <p class="scenario__try">{it.phrase}</p>
          </div>
        ))}
      </div>
      <p class="center mt-5">
        <a class="btn btn--primary" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live"><Icon name="phone" size={18} />{scen.cta} · {SITE.aiPhoneDisplay}</a>
      </p>
    </div>
  </section>

  <!-- ── 4. Six modules — one system ──────────────────────── -->
  <section class="section" id="system">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.systemEyebrow}</span>
        <h2>{c.systemTitle}</h2>
        <p>{c.systemText}</p>
      </div>

      <p class="growthwords">
        {c.growthWords.map((w: string, i: number) => (
          <>
            <span class="growthwords__word">{w}</span>
            {i < c.growthWords.length - 1 && <span class="growthwords__sep" aria-hidden="true">→</span>}
          </>
        ))}
      </p>

      <ol class="system">
        {c.system.map((s: any, i: number) => (
          <li class="system__row">
            <span class="system__num" aria-hidden="true">{s.n}</span>
            <div class="system__body">
              <h3><a href={linkFor(i)} data-track="service_view">{s.title}</a></h3>
              <p>{s.text}</p>
            </div>
            <a class="system__link" href={linkFor(i)} tabindex="-1" aria-hidden="true">→</a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Ecosystem router: the four content pillars ───────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{eco.eyebrow}</span>
        <h2>{eco.title}</h2>
        <p>{eco.text}</p>
      </div>
      <div class="eco-grid">
        {eco.items.map((it) => (
          <a class="eco-card" href={it.href}>
            <h3>{it.title}</h3>
            <p>{it.text}</p>
            <span class="eco-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 5. Method ────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.methodEyebrow}</span>
        <h2>{c.methodTitle}</h2>
        <p>{c.methodText}</p>
      </div>
      <MethodTimeline locale={locale} />
    </div>
  </section>

  <!-- ── 6+7. Implementation proof: voice demo ────────────── -->
  <section class={`section voice-section ${theme === 'b' ? 'section--dark' : ''}`} id="demo">
    <div class="container voice">
      <div>
        <span class="eyebrow">{c.voiceEyebrow}</span>
        <h2>{c.voiceTitle}</h2>
        <p class="mt-3 voice__text">{c.voiceText}</p>
        <p class="mt-4">
          <a class="btn btn--secondary" href={phoneHref}>{c.voiceCta}</a>
        </p>
      </div>
      <video controls preload="none" poster={posterSrc} class="demo-video" data-demo-video>
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </section>

  <!-- ── Calculator (interactive proof) ───────────────────── -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">{c.calcEyebrow}</span>
      <MissedCallsCalculator locale={locale} />
    </div>
  </section>

  <!-- ── 9. Why Weissmann — numbered editorial index ──────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head"><h2>{c.whyTitle}</h2></div>
      <ol class="why">
        {c.why.map((item: string, i: number) => (
          <li class="why__item">
            <span class="why__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Comparison table ─────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{compare.eyebrow}</span>
        <h2>{compare.title}</h2>
        <p>{compare.text}</p>
      </div>
      <div class="cmp-wrap reveal">
        <table class="cmp">
          <thead>
            <tr>
              <td class="cmp__corner"></td>
              {compare.cols.map((col, i) => <th scope="col" class={i === 0 ? 'cmp__win' : ''}>{col}</th>)}
            </tr>
          </thead>
          <tbody>
            {compare.rows.map((row) => (
              <tr>
                <th scope="row">{row.label}</th>
                {row.cells.map((cell, i) => (
                  <td class={i === 0 ? 'cmp__win' : ''}>
                    {typeof cell === 'boolean'
                      ? (cell ? <Icon name="check" size={18} class="cmp__yes" title="Ja" /> : <span class="cmp__no" aria-label="Nein">—</span>)
                      : <span>{cell}</span>}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── Trust & Swiss compliance cluster ─────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{trust.eyebrow}</span>
        <h2>{trust.title}</h2>
        <p>{trust.text}</p>
      </div>
      <div class="trustgrid">
        {trust.pillars.map((pl, i) => (
          <div class="trustpillar reveal" style={`--i:${i}`}>
            <span class="feat-icon"><Icon name={pl.icon} size={22} /></span>
            <h3>{pl.label}</h3>
            <p>{pl.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 11. Pricing overview ─────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{c.pricingEyebrow}</span>
        <h2>{c.pricingTitle}</h2>
        <p>{c.pricingText}</p>
      </div>
      <div class="grid grid--3">
        <PricingCard pkg={phoneStarter} locale={locale} />
        <PricingCard pkg={phonePremium} locale={locale} highlight />
        <PricingCard pkg={websiteStarter} locale={locale} />
      </div>
      <p class="center mt-4">
        <a class="btn btn--ghost" href={`${p}/preise/`} data-track="pricing_view">{t(locale, 'cta.allPricing')} →</a>
      </p>
      <p class="center muted">{t(locale, 'price.vatNote')}</p>
    </div>
  </section>

  <!-- ── AI Smart Glasses — ecosystem cross-sell → ai-eyewear.ch ─ -->
  <section class="section section--alt glasses-section">
    <div class="container">
      <div class="glasses-layout">
        <figure class="glasses-visual reveal">
          <img class="glasses-photo" src="/smart-glasses-worn.webp" width="1651" height="2200"
               alt={c.glasses.title} loading="lazy" decoding="async" />
          <img class="glasses-photo glasses-photo--inset" src="/smart-glasses.webp" width="2000" height="2000"
               alt="" aria-hidden="true" loading="lazy" decoding="async" />
        </figure>
        <div class="glasses-copy reveal">
          <span class="eyebrow">{c.glasses.eyebrow}</span>
          <h2>{c.glasses.title}</h2>
          <p class="glasses-lead">{c.glasses.lead}</p>
          <ul class="glasses-list">
            {c.glasses.features.map((f: any, i: number) => (
              <li><span class="feat-icon glasses-list__icon"><Icon name={GLASSES_ICONS[i]} size={18} /></span>{f.label}</li>
            ))}
          </ul>
          <p class="mt-4">
            <a class="btn btn--primary" href="https://ai-eyewear.ch" rel="noopener" target="_blank" data-track="glasses_view">{c.glasses.ctaLabel} →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Authority: founders + transparent process ────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{authority.eyebrow}</span>
        <h2>{authority.title}</h2>
        <p>{authority.text}</p>
      </div>
      <div class="authority-grid">
        <figure class="team-photo reveal">
          <img src="/founders.jpg" alt={`${authority.founders[0].name} & ${authority.founders[1].name} — Weissmann AI, Zürich`} width="1600" height="1200" loading="lazy" />
          <figcaption>{authority.founders[0].name} · {authority.founders[0].role} · {authority.founders[1].name} · {authority.founders[1].role}</figcaption>
        </figure>
        <div class="process reveal">
          <h3 class="process__title">{authority.processTitle}</h3>
          <ol class="process__steps">
            {authority.steps.map((s, i) => (
              <li><span class="process__n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span><span>{s}</span></li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 13. FAQ ──────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <Faq title={c.faqTitle} items={c.faq} />
    </div>
  </section>

  <!-- ── 14. Final CTA — selective dark moment ────────────── -->
  <section class="section section--dark final-cta">
    <div class="container center">
      <h2 style="max-width:26ch;margin-inline:auto;">{c.finalTitle}</h2>
      <p class="mt-3" style="max-width:38rem;margin-inline:auto;">{c.finalText}</p>
      <div class="hero__actions" style="justify-content:center;">
        <a class="btn btn--primary" href={`${p}/kontakt/`} data-track="book_consultation">{c.heroPrimary}</a>
        <a class="btn btn--secondary" href="tel:+41783459788" data-track="phone_click">{t(locale, 'cta.call')}</a>
      </div>
    </div>
  </section>

  <!-- Weissmann Assistant (homepage preview first) -->
  <WeissmannAssistant locale={locale} />
</Layout>

<style>
  /* ── Hero: premium dark section with animated phone device ── */
  .hero { padding-block: 0; }
  .hero--dark {
    position: relative;
    background: radial-gradient(125% 130% at 82% 0%, #1c2a4a 0%, #0f1729 55%, #0b1018 100%);
    color: #b9c2d6;
    padding-block: clamp(3.25rem, 8vh, 6rem);
    overflow: clip;
  }
  .hero__glow { position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(42% 55% at 78% 20%, rgba(96,138,235,0.24), transparent 72%); }
  .hero__grid { position: relative; display: grid; gap: var(--space-5); align-items: center; }
  @media (min-width: 900px) { .hero__grid { grid-template-columns: 1.02fr 0.98fr; gap: var(--space-6); } }
  .eyebrow--light { color: #8fa6d8; }
  .hero--dark .hero__title {
    color: #fff;
    font-size: clamp(2.5rem, 1.3rem + 4.6vw, 4.5rem);
    max-width: 15ch; letter-spacing: -0.03em; line-height: 1.02;
  }
  .hero__text { max-width: 40rem; margin-top: var(--space-4); font-size: var(--fs-500); color: #aab5cc; line-height: 1.6; }
  .hero__actions { display: flex; gap: var(--space-3); margin-top: var(--space-5); flex-wrap: wrap; }
  .btn--accent { background: #4f7cf0; color: #fff; box-shadow: 0 12px 30px -6px rgba(79,124,240,0.45); }
  .btn--accent:hover { background: #6c92f6; }
  .btn--ondark { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.22); }
  .btn--ondark:hover { border-color: #fff; background: rgba(255,255,255,0.12); }
  .hero__chips { list-style: none; padding: 0; margin: var(--space-4) 0 0; display: flex; flex-wrap: wrap; gap: 0.55rem 1.15rem; font-size: var(--fs-300); color: #9fb0d0; }
  .hero__chips li { display: inline-flex; align-items: center; gap: 0.4rem; }
  .hero__chips .wi { color: #6fe3a4; }

  /* Phone device holding the live-call illustration */
  .hero__visual { justify-self: center; width: 100%; max-width: 21rem; }
  .device { position: relative; border-radius: 40px; padding: 0.5rem; background: linear-gradient(160deg, #3a445e, #1a2236); box-shadow: 0 46px 80px -26px rgba(0,0,0,0.7); animation: floaty 6.5s ease-in-out infinite; }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }
  .device__notch { position: absolute; top: 0.5rem; left: 50%; transform: translateX(-50%); width: 32%; height: 1rem; background: #1a2236; border-radius: 0 0 12px 12px; z-index: 3; }
  .device .callcard { border-radius: 32px; border: none; box-shadow: none; }
  .callcard { margin: 0; border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--paper); overflow: hidden; }
