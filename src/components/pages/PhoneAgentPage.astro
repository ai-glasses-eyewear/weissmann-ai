---
/**
 * AI Phone Agent — flagship solution page. Preserves verified plan facts and
 * the two existing Stripe links (via the central pricing config).
 */
import Layout from '../../layouts/Layout.astro';
import PricingCard from '../PricingCard.astro';
import Faq from '../Faq.astro';
import { localePrefix, localeUrl, type Locale } from '../../data/site';
import { t } from '../../i18n/ui';
import { getPackage } from '../../data/pricing';
import { getService, servicePaths } from '../../data/services';
import { organization, webPage, breadcrumbs, faqPage, serviceWithOffer } from '../../data/schema';

interface Props { locale: Locale }
const { locale } = Astro.props;
const p = localePrefix(locale);
const PATH = '/ki-telefonassistent/';
// Legacy URL kept live for inbound links; the registry-driven phone-assistant
// service is the canonical page, so defer ranking signals to it.
const canonicalUrl = localeUrl(locale, servicePaths(getService('phone-assistant')!)[locale]);

const C: Record<Locale, any> = {
  de: {
    metaTitle: 'KI-Telefonassistent für Schweizer Unternehmen | Weissmann AI',
    metaDesc:
      'Der Weissmann KI-Telefonassistent nimmt jeden Anruf entgegen, bucht Termine und beantwortet Fragen – 24/7, mehrsprachig, mit menschlicher Weiterleitung per Taste 0.',
    h1: 'Der KI-Telefonassistent, der keinen Anruf mehr verpasst',
    intro:
      'Verpasste Anrufe sind verlorener Umsatz. Der Weissmann KI-Telefonassistent beantwortet jeden Anruf – natürlich klingend, mehrsprachig und rund um die Uhr. Er bucht Termine direkt in Ihr System, beantwortet häufige Fragen und leitet komplexe Anliegen an Ihr Team weiter.',
    featuresTitle: 'Was der Assistent für Sie übernimmt',
    features: [
      { title: 'Eingehende Anrufe – 24/7', text: 'Jeder Anruf wird angenommen, auch ausserhalb der Öffnungszeiten, an Feiertagen und in Stosszeiten.' },
      { title: 'Terminbuchung in Echtzeit', text: 'Termine und Reservationen werden direkt in Ihrem bestehenden Buchungssystem eingetragen.' },
      { title: 'Mehrsprachig (DE/EN/FR/IT)', text: 'Ihre Kundschaft wird in ihrer Sprache bedient – je nach Paket in bis zu vier Sprachen.' },
      { title: 'Weiterleitung an Menschen', text: 'Per Taste 0 oder bei Bedarf leitet der Assistent jederzeit an Ihr Team weiter. Sie behalten die Kontrolle.' },
