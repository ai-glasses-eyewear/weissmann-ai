---
/**
 * ServicePage — the reusable template for every dedicated service landing page
 * (docs/architecture/MASTER-PAGE-MAP.md §4). Renders from services.ts (identity
 * + routing + relations), service-content.ts (long-form copy) and pricing.ts
 * (prices + Offer schema). One consistent, authoritative structure per service:
 * answer-first hero, benefits, body, transparent pricing, FAQ, CTA + full schema.
 */
import { SITE, localeUrl, type Locale } from '../../data/site';
import { type LocalePaths, pillarHome, urlFor, relFor } from '../../data/routes';
import { type ServiceDef, servicePaths } from '../../data/services';
import type { ServiceContent } from '../../data/service-content';
import { getIndustry, industryPaths } from '../../data/industries';
import { getCluster, clusterPaths, pillarOf } from '../../data/academy';
import { getPackage } from '../../data/pricing';
import { breadcrumbs, faqPage, serviceWithOffer, webPage } from '../../data/schema';
import { t } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import Faq from '../Faq.astro';
import Icon from '../Icon.astro';
import PricingCard from '../PricingCard.astro';

interface Props {
  locale: Locale;
  localePaths: LocalePaths;
  service: ServiceDef;
  content: ServiceContent;
}
const { locale, localePaths, service, content } = Astro.props;

const LBL: Record<Locale, { short: string; faq: string; pricing: string; whoTitle: string; ctaTitle: string; ctaText: string; onRequest: string; socialProof: string; reassure: string; demoBtn: string; hearAi: string }> = {
  de: { short: 'Kurzantwort', faq: 'Häufige Fragen', pricing: 'Pakete & Preise', whoTitle: 'Für wen', ctaTitle: 'Bereit, loszulegen?', ctaText: 'Erzählen Sie uns kurz von Ihrer Situation – wir zeigen Ihnen, was mit KI konkret möglich ist.', onRequest: 'Preis auf Anfrage', socialProof: 'Über 20 Unternehmen haben bereits eine Live-Demo angefragt.', reassure: 'Kostenlos · ca. 15 Min · unverbindlich', demoBtn: '15-Min-Demo buchen', hearAi: 'Unsere KI live hören' },
  en: { short: 'In short', faq: 'Frequently asked questions', pricing: 'Packages & pricing', whoTitle: 'Who it’s for', ctaTitle: 'Ready to get started?', ctaText: 'Tell us briefly about your situation – we’ll show you what AI can concretely do for you.', onRequest: 'Price on request', socialProof: 'More than 20 businesses have already requested a live demo.', reassure: 'Free · ~15 min · no obligation', demoBtn: 'Book a 15-min demo', hearAi: 'Hear our AI live' },
  it: { short: 'In breve', faq: 'Domande frequenti', pricing: 'Pacchetti e prezzi', whoTitle: 'Per chi', ctaTitle: 'Pronti a iniziare?', ctaText: 'Raccontateci brevemente la vostra situazione – vi mostriamo cosa può fare concretamente l’AI.', onRequest: 'Prezzo su richiesta', socialProof: 'Oltre 20 aziende hanno già richiesto una demo dal vivo.', reassure: 'Gratis · ~15 min · senza impegno', demoBtn: 'Prenota una demo di 15 min', hearAi: 'Ascolta la nostra AI dal vivo' },
  fr: { short: 'En bref', faq: 'Questions fréquentes', pricing: 'Forfaits et tarifs', whoTitle: 'Pour qui', ctaTitle: 'Prêt à démarrer ?', ctaText: 'Parlez-nous brièvement de votre situation – nous vous montrons ce que l’IA peut concrètement faire.', onRequest: 'Prix sur demande', socialProof: 'Plus de 20 entreprises ont déjà demandé une démo en direct.', reassure: 'Gratuit · ~15 min · sans engagement', demoBtn: 'Réserver une démo de 15 min', hearAi: 'Écoutez notre IA en direct' },
};
const lbl = LBL[locale];

const pre = locale === 'de' ? '' : `/${locale}`;
const demoHref = `${pre}/kontakt/#demo-form`;
const pricingHref = `${pre}/preise/`;

const hubPaths = pillarHome('services');
const selfUrl = urlFor(locale, localePaths);

const packages = content.pricingIds.map((id) => getPackage(id));

// Internal-link the service to its industries + informational Academy cluster
// (data already on the ServiceDef) — only to published targets.
const relIndustries = (service.relatedIndustries ?? [])
  .map((id) => getIndustry(id))
  .filter((i): i is NonNullable<typeof i> => !!i && i.status === 'live');
const relClusters = (service.relatedAcademy ?? [])
  .map((id) => getCluster(id))
  .filter((c): c is NonNullable<typeof c> => !!c && c.status === 'live' && !!pillarOf(c.id));
const relLabels = {
  de: { industries: 'Für welche Branchen', learn: 'Verstehen: in der AI Academy' },
  en: { industries: 'Industries we serve', learn: 'Understand it: in the AI Academy' },
  it: { industries: 'Per quali settori', learn: 'Approfondire: nell’AI Academy' },
  fr: { industries: 'Pour quels secteurs', learn: 'Comprendre : dans l’AI Academy' },
}[locale];

const crumbName = { de: 'Startseite', en: 'Home', it: 'Home', fr: 'Accueil' }[locale];
const svcCrumb = { de: 'Leistungen', en: 'Services', it: 'Servizi', fr: 'Services' }[locale];

const schema = [
  webPage(locale, localePaths[locale], content.h1[locale], content.metaDescription[locale]),
  breadcrumbs(locale, [
    { name: crumbName, path: '/' },
    { name: svcCrumb, path: hubPaths[locale] },
    { name: service.name[locale], path: localePaths[locale] },
  ]),
  faqPage(content.faq.map((f) => ({ q: f.q[locale], a: f.a[locale] }))),
  ...packages.filter((p) => p.schemaOffer).map((p) => serviceWithOffer(locale, p, localePaths[locale])),
];
---
<Layout locale={locale} localePaths={localePaths} title={content.title[locale]} description={content.metaDescription[locale]} schema={schema}>
  <Breadcrumbs locale={locale} items={[
    { name: crumbName, href: `${pre}/` },
    { name: svcCrumb, href: urlFor(locale, hubPaths).replace(SITE.domain, '') },
    { name: service.name[locale] },
  ]} />

  <header class="svc-hero container">
    <p class="kicker">{content.kicker[locale]}</p>
    <h1>{content.h1[locale]}</h1>
    <p class="svc-lead">{service.tagline[locale]}</p>
    <p class="svc-proof"><Icon name="users" size={18} />{lbl.socialProof}</p>
    <div class="svc-cta-row">
      <a class="btn btn--primary" href={demoHref} data-track="book_consultation">{lbl.demoBtn}</a>
      <a class="btn btn--ghost" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live"><Icon name="phone" size={18} />{lbl.hearAi} · {SITE.aiPhoneDisplay}</a>
    </div>
    <p class="svc-reassure">{lbl.reassure}</p>
    <aside class="tldr" aria-label={lbl.short}>
      <span class="tldr__label">{lbl.short}</span>
      <p>{content.answerFirst[locale]}</p>
    </aside>
  </header>

  <section class="container svc-benefits">
    <div class="svc-benefit-grid">
      {content.benefits.map((b, i) => (
        <article class="benefit">
          <span class="benefit__n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <h2>{b.title[locale]}</h2>
          <p>{b.text[locale]}</p>
        </article>
      ))}
    </div>
  </section>

  {content.sections.map((s) => (
    <section class="container svc-section">
      <h2>{s.heading[locale]}</h2>
      {s.paragraphs?.map((p) => <p>{p[locale]}</p>)}
      {s.bullets && s.bullets.length > 0 && (
        <ul class="svc-bullets">
          {s.bullets.map((b) => <li>{b[locale]}</li>)}
        </ul>
      )}
    </section>
  ))}

  {packages.length > 0 && (
    <section class="container svc-pricing" id="preise">
      <h2>{lbl.pricing}</h2>
      <div class="price-grid">
        {packages.map((p) => <PricingCard pkg={p} locale={locale} />)}
      </div>
      <p class="price-note">{t(locale, 'price.vatNote')} · <a href={pricingHref}>{t(locale, 'cta.allPricing')}</a></p>
    </section>
  )}

  <section class="container svc-faq">
    <h2>{lbl.faq}</h2>
    <Faq items={content.faq.map((f) => ({ q: f.q[locale], a: f.a[locale] }))} />
  </section>

  {(relIndustries.length > 0 || relClusters.length > 0) && (
    <section class="container svc-links">
      {relIndustries.length > 0 && (
        <div class="svc-links__group">
          <h2>{relLabels.industries}</h2>
          <ul class="chip-row">
            {relIndustries.map((i) => (
              <li><a class="chip" href={relFor(locale, industryPaths(i))}>{i.name[locale]}</a></li>
            ))}
          </ul>
        </div>
      )}
      {relClusters.length > 0 && (
        <div class="svc-links__group">
          <h2>{relLabels.learn}</h2>
          <ul class="chip-row">
            {relClusters.map((c) => (
              <li><a class="chip" href={relFor(locale, clusterPaths(c))}>{c.name[locale]}</a></li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <section class="container svc-cta">
    <h2>{lbl.ctaTitle}</h2>
    <p>{lbl.ctaText}</p>
    <div class="svc-cta-row svc-cta-row--center">
      <a class="btn btn--primary" href={demoHref} data-track="book_consultation">{lbl.demoBtn}</a>
      <a class="btn btn--ghost" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live"><Icon name="phone" size={18} />{lbl.hearAi} · {SITE.aiPhoneDisplay}</a>
    </div>
  </section>
</Layout>

<style>
  .svc-hero { padding-top: var(--space-5); padding-bottom: var(--space-6); max-width: 62rem; }
  .svc-hero h1 { font-size: var(--fs-700); line-height: 1.05; margin: 0.4rem 0 1rem; }
  .svc-lead { font-size: var(--fs-400); color: var(--ink-soft); max-width: 48rem; }
  .svc-cta-row { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-4); }
  .svc-cta-row--center { justify-content: center; }
  .svc-proof { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: var(--space-4); font-size: var(--fs-300); color: var(--ink-soft); font-weight: 600; }
  .svc-proof :global(.wi) { color: var(--accent); flex-shrink: 0; }
  .svc-reassure { margin-top: 0.7rem; font-size: var(--fs-200); color: var(--ink-mute); }
  .tldr { margin-top: var(--space-5); border-left: 3px solid var(--accent); background: color-mix(in srgb, var(--accent) 6%, transparent); border-radius: 0 12px 12px 0; padding: var(--space-4); }
  .tldr__label { text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--fs-200); color: var(--accent); font-weight: 700; }
  .tldr p { margin: 0.4rem 0 0; color: var(--ink); font-size: var(--fs-400); }
  .svc-benefits { padding-bottom: var(--space-5); }
  .svc-benefit-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: var(--space-4); }
  .benefit { border: 1px solid var(--line); border-radius: 14px; padding: var(--space-4); background: var(--paper); transition: border-color 0.2s ease; }
  .benefit:hover { border-color: color-mix(in srgb, var(--accent) 40%, var(--line)); }
  .benefit__n { display: block; font-variant-numeric: tabular-nums; font-weight: 700; color: var(--accent); font-size: var(--fs-300); letter-spacing: 0.05em; margin-bottom: 0.4rem; }
  .benefit h2 { font-size: var(--fs-400); margin: 0 0 0.4rem; }
  .benefit p { margin: 0; color: var(--ink-soft); font-size: var(--fs-300); }
  .svc-section { padding-bottom: var(--space-5); max-width: 56rem; }
  .svc-section h2 { font-size: var(--fs-600); margin-bottom: var(--space-3); }
  .svc-section p { color: var(--ink-soft); margin-bottom: var(--space-3); }
  .svc-bullets { display: flex; flex-direction: column; gap: 0.6rem; padding-left: 1.1rem; }
  .svc-bullets li { color: var(--ink-soft); }
  .svc-pricing { padding: var(--space-6) var(--space-4); }
  .svc-pricing > h2 { font-size: var(--fs-600); margin-bottom: var(--space-4); }
  .price-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr)); gap: var(--space-4); }
  .price-note { font-size: var(--fs-200); color: var(--ink-mute); margin-top: var(--space-4); }
  .svc-faq { padding-bottom: var(--space-6); max-width: 54rem; }
  .svc-faq > h2 { font-size: var(--fs-600); margin-bottom: var(--space-4); }
  .svc-links { display: grid; gap: var(--space-5); padding-bottom: var(--space-6); max-width: 60rem; }
  .svc-links__group h2 { font-size: var(--fs-400); margin-bottom: var(--space-3); }
  .chip-row { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .svc-cta { text-align: center; padding: var(--space-7) var(--space-4); margin-bottom: var(--space-7); border-top: 1px solid var(--line); }
  .svc-cta h2 { font-size: var(--fs-600); margin-bottom: 0.6rem; }
  .svc-cta p { color: var(--ink-soft); max-width: 40rem; margin: 0 auto var(--space-4); }
</style>
