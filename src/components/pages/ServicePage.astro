---
/**
 * ServicePage — the reusable template for every dedicated service landing page
 * (docs/architecture/MASTER-PAGE-MAP.md §4). Renders from services.ts (identity
 * + routing + relations), service-content.ts (long-form copy) and pricing.ts
 * (prices + Offer schema). One consistent, authoritative structure per service:
 * answer-first hero, benefits, body, transparent pricing, FAQ, CTA + full schema.
 */
import { SITE, localeUrl, type Locale } from '../../data/site';
import { type LocalePaths, pillarHome, urlFor } from '../../data/routes';
import { type ServiceDef, servicePaths } from '../../data/services';
import type { ServiceContent } from '../../data/service-content';
import { getPackage, formatPrice } from '../../data/pricing';
import { breadcrumbs, faqPage, serviceWithOffer, webPage } from '../../data/schema';
import { t } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
  localePaths: LocalePaths;
  service: ServiceDef;
  content: ServiceContent;
}
const { locale, localePaths, service, content } = Astro.props;

const LBL: Record<Locale, { short: string; faq: string; pricing: string; whoTitle: string; ctaTitle: string; ctaText: string; onRequest: string }> = {
  de: { short: 'Kurzantwort', faq: 'Häufige Fragen', pricing: 'Pakete & Preise', whoTitle: 'Für wen', ctaTitle: 'Bereit, loszulegen?', ctaText: 'Erzählen Sie uns kurz von Ihrer Situation – wir zeigen Ihnen, was mit KI konkret möglich ist.', onRequest: 'Preis auf Anfrage' },
  en: { short: 'In short', faq: 'Frequently asked questions', pricing: 'Packages & pricing', whoTitle: 'Who it’s for', ctaTitle: 'Ready to get started?', ctaText: 'Tell us briefly about your situation – we’ll show you what AI can concretely do for you.', onRequest: 'Price on request' },
  it: { short: 'In breve', faq: 'Domande frequenti', pricing: 'Pacchetti e prezzi', whoTitle: 'Per chi', ctaTitle: 'Pronti a iniziare?', ctaText: 'Raccontateci brevemente la vostra situazione – vi mostriamo cosa può fare concretamente l’AI.', onRequest: 'Prezzo su richiesta' },
  fr: { short: 'En bref', faq: 'Questions fréquentes', pricing: 'Forfaits et tarifs', whoTitle: 'Pour qui', ctaTitle: 'Prêt à démarrer ?', ctaText: 'Parlez-nous brièvement de votre situation – nous vous montrons ce que l’IA peut concrètement faire.', onRequest: 'Prix sur demande' },
};
const lbl = LBL[locale];

const pre = locale === 'de' ? '' : `/${locale}`;
const contactHref = `${pre}/kontakt/`;
const pricingHref = `${pre}/preise/`;

const hubPaths = pillarHome('services');
const selfUrl = urlFor(locale, localePaths);

const packages = content.pricingIds.map((id) => getPackage(id));

const crumbName = { de: 'Startseite', en: 'Home', it: 'Home', fr: 'Accueil' }[locale];
const svcCrumb = { de: 'Leistungen', en: 'Services', it: 'Servizi', fr: 'Services' }[locale];

const schema = [
  webPage(locale, localePaths[locale], content.h1[locale], content.metaDescription[locale]),
  breadcrumbs(locale, [
    { name: crumbName, path: '/' },
    { name: svcCrumb, path: hubPaths[locale] },
    { name: service.name[locale], path: localePaths[locale] },
  ]),
  faqPage(content.faq.map((f) => ({ q: f.q[locale], a: f.a[locale] }))),
  ...packages.filter((p) => p.schemaOffer).map((p) => serviceWithOffer(locale, p, localePaths[locale])),
];

function priceDisplay(id: string): string {
  const p = getPackage(id);
  if (p.price === null) return lbl.onRequest;
  const amount = formatPrice(p.price);
  const withFrom = p.isFrom ? `${t(locale, 'price.from')} ${amount}` : amount;
  return p.interval === 'month' ? `${withFrom} / ${t(locale, 'price.month')}` : `${withFrom} · ${t(locale, 'price.once')}`;
}
---
<Layout locale={locale} localePaths={localePaths} title={content.title[locale]} description={content.metaDescription[locale]} schema={schema}>
  <nav class="crumbs container" aria-label="Breadcrumb">
    <a href={`${pre}/`}>{crumbName}</a><span aria-hidden="true">›</span>
    <a href={urlFor(locale, hubPaths).replace(SITE.domain, '')}>{svcCrumb}</a><span aria-hidden="true">›</span>
    <span>{service.name[locale]}</span>
  </nav>

  <header class="svc-hero container">
    <p class="kicker">{content.kicker[locale]}</p>
    <h1>{content.h1[locale]}</h1>
    <p class="svc-lead">{service.tagline[locale]}</p>
    <div class="svc-cta-row">
      <a class="btn btn--primary" href={contactHref} data-track="request_demo">{t(locale, 'cta.demo')}</a>
      <a class="btn btn--ghost" href={`tel:${SITE.phone}`} data-track="call">{t(locale, 'cta.call')}</a>
    </div>
    <aside class="tldr" aria-label={lbl.short}>
      <span class="tldr__label">{lbl.short}</span>
      <p>{content.answerFirst[locale]}</p>
    </aside>
  </header>

  <section class="container svc-benefits">
    <div class="svc-benefit-grid">
      {content.benefits.map((b) => (
        <article class="benefit">
          <h2>{b.title[locale]}</h2>
          <p>{b.text[locale]}</p>
        </article>
      ))}
    </div>
  </section>

  {content.sections.map((s) => (
    <section class="container svc-section">
      <h2>{s.heading[locale]}</h2>
      {s.paragraphs?.map((p) => <p>{p[locale]}</p>)}
      {s.bullets && s.bullets.length > 0 && (
        <ul class="svc-bullets">
          {s.bullets.map((b) => <li>{b[locale]}</li>)}
        </ul>
      )}
    </section>
  ))}

  {packages.length > 0 && (
    <section class="container svc-pricing" id="preise">
      <h2>{lbl.pricing}</h2>
      <div class="price-grid">
        {packages.map((p) => (
          <article class="price-card">
            <h3>{p.name[locale]}</h3>
            <p class="price-card__price">{priceDisplay(p.id)}</p>
            <p class="price-card__desc">{p.description[locale]}</p>
            <ul>
              {p.features[locale].slice(0, 4).map((f) => <li>{f}</li>)}
            </ul>
            <ul class="price-card__disc">
              {p.disclosures[locale].map((d) => <li>{d}</li>)}
            </ul>
            {p.ctaType === 'stripe' && p.stripeLink
              ? <a class="btn btn--primary" href={p.stripeLink} rel="nofollow" data-track="checkout">{t(locale, 'cta.buy')}</a>
              : <a class="btn btn--ghost" href={contactHref} data-track="request_demo">{t(locale, 'cta.consultation')}</a>}
          </article>
        ))}
      </div>
      <p class="price-note">{t(locale, 'price.vatNote')} · <a href={pricingHref}>{t(locale, 'cta.allPricing')}</a></p>
    </section>
  )}

  <section class="container svc-faq">
    <h2>{lbl.faq}</h2>
    <div class="faq-list">
      {content.faq.map((f) => (
        <details class="faq-item">
          <summary>{f.q[locale]}</summary>
          <p>{f.a[locale]}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="container svc-cta">
    <h2>{lbl.ctaTitle}</h2>
    <p>{lbl.ctaText}</p>
    <div class="svc-cta-row svc-cta-row--center">
      <a class="btn btn--primary" href={contactHref} data-track="request_demo">{t(locale, 'nav.cta')}</a>
      <a class="btn btn--ghost" href={SITE.whatsapp} rel="nofollow" data-track="whatsapp">{t(locale, 'cta.whatsapp')}</a>
    </div>
  </section>
</Layout>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; font-size: var(--fs-200); color: var(--ink-mute); padding-top: var(--space-5); flex-wrap: wrap; }
  .crumbs a { color: var(--ink-mute); }
  .crumbs a:hover { color: var(--ink); }
  .svc-hero { padding-top: var(--space-5); padding-bottom: var(--space-6); max-width: 62rem; }
  .svc-hero h1 { font-size: var(--fs-700); line-height: 1.05; margin: 0.4rem 0 1rem; }
  .kicker { text-transform: uppercase; letter-spacing: 0.12em; font-size: var(--fs-200); color: var(--accent); font-weight: 600; }
  .svc-lead { font-size: var(--fs-400); color: var(--ink-soft); max-width: 48rem; }
  .svc-cta-row { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-4); }
  .svc-cta-row--center { justify-content: center; }
  .tldr { margin-top: var(--space-5); border-left: 3px solid var(--accent); background: color-mix(in srgb, var(--accent) 6%, transparent); border-radius: 0 12px 12px 0; padding: var(--space-4); }
  .tldr__label { text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--fs-200); color: var(--accent); font-weight: 700; }
  .tldr p { margin: 0.4rem 0 0; color: var(--ink); font-size: var(--fs-400); }
  .svc-benefits { padding-bottom: var(--space-5); }
  .svc-benefit-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: var(--space-4); }
  .benefit { border: 1px solid var(--line); border-radius: 14px; padding: var(--space-4); background: var(--paper); }
  .benefit h2 { font-size: var(--fs-400); margin: 0 0 0.4rem; }
  .benefit p { margin: 0; color: var(--ink-soft); font-size: var(--fs-300); }
  .svc-section { padding-bottom: var(--space-5); max-width: 56rem; }
  .svc-section h2 { font-size: var(--fs-600); margin-bottom: var(--space-3); }
  .svc-section p { color: var(--ink-soft); margin-bottom: var(--space-3); }
  .svc-bullets { display: flex; flex-direction: column; gap: 0.6rem; padding-left: 1.1rem; }
  .svc-bullets li { color: var(--ink-soft); }
  .svc-pricing { padding: var(--space-6) var(--space-4); }
  .svc-pricing > h2 { font-size: var(--fs-600); margin-bottom: var(--space-4); }
  .price-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr)); gap: var(--space-4); }
  .price-card { border: 1px solid var(--line); border-radius: 16px; padding: var(--space-5); background: var(--paper); display: flex; flex-direction: column; gap: 0.6rem; }
  .price-card h3 { font-size: var(--fs-500); margin: 0; }
  .price-card__price { font-size: var(--fs-500); font-weight: 700; color: var(--accent); margin: 0; }
  .price-card__desc { color: var(--ink-soft); font-size: var(--fs-300); margin: 0; }
  .price-card ul { list-style: none; padding: 0; margin: 0.4rem 0; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .price-card li { position: relative; padding-left: 1.3rem; font-size: var(--fs-300); color: var(--ink-soft); }
  .price-card li::before { content: "→"; position: absolute; left: 0; color: var(--accent); }
  .price-card__disc li { font-size: var(--fs-200); color: var(--ink-mute); }
  .price-card__disc li::before { content: "·"; }
  .price-note { font-size: var(--fs-200); color: var(--ink-mute); margin-top: var(--space-4); }
  .svc-faq { padding-bottom: var(--space-6); max-width: 54rem; }
  .svc-faq > h2 { font-size: var(--fs-600); margin-bottom: var(--space-4); }
  .faq-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .faq-item { border: 1px solid var(--line); border-radius: 12px; padding: var(--space-3) var(--space-4); background: var(--paper); }
  .faq-item summary { font-weight: 600; cursor: pointer; }
  .faq-item p { margin: 0.6rem 0 0; color: var(--ink-soft); }
  .svc-cta { text-align: center; padding: var(--space-7) var(--space-4); margin-bottom: var(--space-7); border-top: 1px solid var(--line); }
  .svc-cta h2 { font-size: var(--fs-600); margin-bottom: 0.6rem; }
  .svc-cta p { color: var(--ink-soft); max-width: 40rem; margin: 0 auto var(--space-4); }
</style>
