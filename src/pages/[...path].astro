---
/**
 * Registry-driven catch-all — the single route that generates every localized,
 * siloed page from the data registries (docs/architecture/MASTER-PAGE-MAP.md).
 * getStaticPaths emits an explicit path per locale (localized slugs), and each
 * entry carries a `type` + data that selects the right template below.
 *
 * Hand-written pages in src/pages/** take precedence over this catch-all, so
 * legacy pages keep working while sections migrate here one at a time.
 */
import { LOCALES, type Locale } from '../data/site';
import { pillarHome, routeParam, type LocalePaths } from '../data/routes';
import { liveServices, servicePaths, type ServiceDef } from '../data/services';
import { getServiceContent, type ServiceContent } from '../data/service-content';
import { liveIndustries, industryPaths, type IndustryDef } from '../data/industries';
import { getIndustryContent, type IndustryContent } from '../data/industry-content';
import { liveClusters, clusterPaths, pillarOf, spokesOf, articlePaths, type AcademyArticle, type AcademyCluster } from '../data/academy';
import { liveResources, resourcePaths, type ResourceDef } from '../data/resources';
import { getChecklistContent, type ChecklistContent } from '../data/resource-content';
import { hasGlossary, glossaryHubPaths, termPaths, GLOSSARY, type GlossaryTerm } from '../data/glossary';
import { liveCompanyPages, companyPagePaths, getCompanyContent, type CompanyPageDef, type CompanyContent } from '../data/company';
import ServicesHubPage from '../components/pages/ServicesHubPage.astro';
import ServicePage from '../components/pages/ServicePage.astro';
import IndustriesHubPage from '../components/pages/IndustriesHubPage.astro';
import IndustryPage from '../components/pages/IndustryPage.astro';
import AcademyHubPage from '../components/pages/AcademyHubPage.astro';
import AcademyArticlePage from '../components/pages/AcademyArticlePage.astro';
import ResourcesHubPage from '../components/pages/ResourcesHubPage.astro';
import PhoneRoiCalculatorPage from '../components/pages/PhoneRoiCalculatorPage.astro';
import ChecklistResourcePage from '../components/pages/ChecklistResourcePage.astro';
import GlossaryHubPage from '../components/pages/GlossaryHubPage.astro';
import GlossaryTermPage from '../components/pages/GlossaryTermPage.astro';
import CompanyPage from '../components/pages/CompanyPage.astro';

export function getStaticPaths() {
  const out: Array<{ params: { path: string }; props: Record<string, unknown> }> = [];

  // Services hub (/leistungen/, /en/services/, /it/servizi/, /fr/services/)
  const servicesHub = pillarHome('services');
  for (const l of LOCALES) {
    out.push({
      params: { path: routeParam(l, servicesHub) },
      props: { type: 'services-hub', locale: l, localePaths: servicesHub },
    });
  }

  // Dedicated service pages (live services only)
  for (const s of liveServices()) {
    const content = getServiceContent(s.id);
    if (!content) continue; // never publish a service page without its content
    const sp = servicePaths(s);
    for (const l of LOCALES) {
      out.push({
        params: { path: routeParam(l, sp) },
        props: { type: 'service', locale: l, localePaths: sp, service: s, content },
      });
    }
  }

  // Industries hub (/branchen/, /en/industries/, /it/settori/, /fr/secteurs/)
  const industriesHub = pillarHome('industries');
  for (const l of LOCALES) {
    out.push({
      params: { path: routeParam(l, industriesHub) },
      props: { type: 'industries-hub', locale: l, localePaths: industriesHub },
    });
  }

  // Dedicated industry pages (live industries only)
  for (const ind of liveIndustries()) {
    const content = getIndustryContent(ind.id);
    if (!content) continue;
    const ip = industryPaths(ind);
    for (const l of LOCALES) {
      out.push({
        params: { path: routeParam(l, ip) },
        props: { type: 'industry', locale: l, localePaths: ip, industry: ind, content },
      });
    }
  }

  // AI Academy hub (/ki-academy/, /en/ai-academy/, /it/ai-academy/, /fr/academie-ia/)
  const academyHub = pillarHome('academy');
  for (const l of LOCALES) {
    out.push({
      params: { path: routeParam(l, academyHub) },
      props: { type: 'academy-hub', locale: l, localePaths: academyHub },
    });
  }

  // Academy cluster pillars (at the cluster path) + spokes (nested), live clusters only
  for (const cl of liveClusters()) {
    const pillar = pillarOf(cl.id);
    if (pillar) {
      const cp = clusterPaths(cl);
      for (const l of LOCALES) {
        out.push({
          params: { path: routeParam(l, cp) },
          props: { type: 'academy-article', locale: l, localePaths: cp, article: pillar, cluster: cl },
        });
      }
    }
    for (const sp of spokesOf(cl.id)) {
      const ap = articlePaths(sp);
      for (const l of LOCALES) {
        out.push({
          params: { path: routeParam(l, ap) },
          props: { type: 'academy-article', locale: l, localePaths: ap, article: sp, cluster: cl },
        });
      }
    }
  }

  // AI Glossary (under the Academy pillar): hub + one page per term
  if (hasGlossary()) {
    const glossHub = glossaryHubPaths();
    for (const l of LOCALES) {
      out.push({ params: { path: routeParam(l, glossHub) }, props: { type: 'glossary-hub', locale: l, localePaths: glossHub } });
    }
    for (const term of GLOSSARY) {
      const tp = termPaths(term);
      for (const l of LOCALES) {
        out.push({ params: { path: routeParam(l, tp) }, props: { type: 'glossary-term', locale: l, localePaths: tp, term } });
      }
    }
  }

  // Resources hub (/ressourcen/, /en/resources/, /it/risorse/, /fr/ressources/)
  const resourcesHub = pillarHome('resources');
  for (const l of LOCALES) {
    out.push({
      params: { path: routeParam(l, resourcesHub) },
      props: { type: 'resources-hub', locale: l, localePaths: resourcesHub },
    });
  }

  // Live resource pages (each renders its dedicated product component)
  for (const r of liveResources()) {
    const rp = resourcePaths(r);
    if (r.type === 'checklist') {
      const cc = getChecklistContent(r.id);
      if (!cc) continue; // never publish a checklist without its content
      for (const l of LOCALES) {
        out.push({
          params: { path: routeParam(l, rp) },
          props: { type: 'resource-checklist', locale: l, localePaths: rp, resource: r, checklist: cc },
        });
      }
    } else {
      for (const l of LOCALES) {
        out.push({
          params: { path: routeParam(l, rp) },
          props: { type: 'resource', locale: l, localePaths: rp, resourceId: r.id },
        });
      }
    }
  }

  // Company pages (flat localized paths: /methodik/, /technologie/, /datensicherheit/ …)
  for (const cp of liveCompanyPages()) {
    const content = getCompanyContent(cp.id);
    if (!content) continue;
    const pp = companyPagePaths(cp);
    for (const l of LOCALES) {
      out.push({
        params: { path: routeParam(l, pp) },
        props: { type: 'company', locale: l, localePaths: pp, companyPage: cp, companyContent: content },
      });
    }
  }

  return out;
}

const props = Astro.props as {
  type: string;
  locale: Locale;
  localePaths: LocalePaths;
  service?: ServiceDef;
  content?: ServiceContent;
  industry?: IndustryDef;
  article?: AcademyArticle;
  cluster?: AcademyCluster;
  resourceId?: string;
  term?: GlossaryTerm;
  companyPage?: CompanyPageDef;
  companyContent?: CompanyContent;
  resource?: ResourceDef;
  checklist?: ChecklistContent;
};
const { type, locale, localePaths, service, content, industry, article, cluster, resourceId, term, companyPage, companyContent, resource, checklist } = props;
const industryContent = props.content as unknown as IndustryContent | undefined;
---
{type === 'services-hub' && <ServicesHubPage locale={locale} localePaths={localePaths} />}
{type === 'service' && service && content && (
  <ServicePage locale={locale} localePaths={localePaths} service={service} content={content} />
)}
{type === 'industries-hub' && <IndustriesHubPage locale={locale} localePaths={localePaths} />}
{type === 'industry' && industry && industryContent && (
  <IndustryPage locale={locale} localePaths={localePaths} industry={industry} content={industryContent} />
)}
{type === 'academy-hub' && <AcademyHubPage locale={locale} localePaths={localePaths} />}
{type === 'academy-article' && article && cluster && (
  <AcademyArticlePage locale={locale} localePaths={localePaths} article={article} cluster={cluster} />
)}
{type === 'resources-hub' && <ResourcesHubPage locale={locale} localePaths={localePaths} />}
{type === 'resource' && resourceId === 'phone-roi-calculator' && (
  <PhoneRoiCalculatorPage locale={locale} localePaths={localePaths} />
)}
{type === 'resource-checklist' && resource && checklist && (
  <ChecklistResourcePage locale={locale} localePaths={localePaths} resource={resource} content={checklist} />
)}
{type === 'glossary-hub' && <GlossaryHubPage locale={locale} localePaths={localePaths} />}
{type === 'glossary-term' && term && (
  <GlossaryTermPage locale={locale} localePaths={localePaths} term={term} />
)}
{type === 'company' && companyPage && companyContent && (
  <CompanyPage locale={locale} localePaths={localePaths} page={companyPage} content={companyContent} />
)}
