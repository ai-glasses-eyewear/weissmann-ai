---
/**
 * Site-wide layout: head (SEO/hreflang/OG/verification), analytics with
 * Consent Mode v2, header, footer, skip link.
 *
 * Props:
 *  - locale: current page locale
 *  - path: locale-independent path starting with '/' (e.g. '/preise/').
 *    Used to build canonical + reciprocal hreflang for all four locales.
 *  - title / description: localized meta
 *  - availableLocales: locales this page actually exists in (defaults to all).
 *  - schema: optional array of JSON-LD objects rendered as one @graph.
 */
import { SITE, LOCALES, HTML_LANG, localeUrl, localePrefix, type Locale } from '../data/site';
import type { LocalePaths } from '../data/routes';
import { organization, webSite, localBusiness } from '../data/schema';
import { t } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentAnalytics from '../components/ConsentAnalytics.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import '../styles/global.css';

interface Props {
  locale: Locale;
  /** Locale-independent path (German-slug pages that reuse one path across locales). */
  path?: string;
  /**
   * Localized path per locale (siloed/localized-slug pages). Preferred over
   * `path`; drives canonical, hreflang and the language switcher. Exactly one
   * of `path` / `localePaths` should be provided.
   */
  localePaths?: LocalePaths;
  title: string;
  description: string;
  availableLocales?: Locale[];
  schema?: object[];
  noindex?: boolean;
  /**
   * Absolute canonical URL override. Set on legacy/duplicate pages that should
   * defer their ranking signals to a registry page at a different URL. When
   * provided, hreflang alternates are suppressed (the canonical cluster owns
   * the language graph).
   */
  canonical?: string;
}

const { locale, path, localePaths, title, description, availableLocales = [...LOCALES], schema = [], noindex = false, canonical: canonicalOverride } = Astro.props;

// Unify: a per-locale path map, whether the page passed localePaths or a single path.
const lp: LocalePaths = localePaths ?? { de: path!, en: path!, it: path!, fr: path! };

const canonical = canonicalOverride ?? localeUrl(locale, lp[locale]);
const ogImage = `${SITE.domain}/og-default.png`;

// Keep meta descriptions within the ~160-char SERP display budget (trim at a
// word boundary and add an ellipsis so the snippet reads as intentional rather
// than cut mid-phrase). Page content is unaffected; only the meta tag changes.
const metaDescription =
  description.length > 160 ? description.slice(0, 157).replace(/\s+\S*$/, '').trim() + '…' : description;

// x-default should target a page that actually exists: prefer English, but fall
// back to the first available locale (e.g. the de-only 404 page).
const xDefaultLocale = availableLocales.includes('en') ? 'en' : availableLocales[0];

// Every page carries the Organization + WebSite entity (defined once here), so
// the @id references in page-level schema (publisher/provider/about) resolve and
// the entity graph is present site-wide for search engines and AI assistants.
const graph = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [organization(locale), webSite(locale), localBusiness(locale), ...schema],
});

// Visual concept: 'b' (Premium Technology) is the approved default.
// 'a' (Swiss Editorial) remains previewable via PUBLIC_THEME=a npm run build.
const theme = (import.meta.env.PUBLIC_THEME as string) === 'a' ? 'a' : 'b';
---

<!doctype html>
<html lang={HTML_LANG[locale]} data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    {!canonicalOverride && (
      <>
        {availableLocales.map((l) => (
          <link rel="alternate" hreflang={l === 'de' ? 'de-CH' : l} href={localeUrl(l, lp[l])} />
        ))}
        <link rel="alternate" hreflang="x-default" href={localeUrl(xDefaultLocale, lp[xDefaultLocale])} />
      </>
    )}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="google-site-verification" content={SITE.tracking.googleSiteVerification} />
    <meta name="msvalidate.01" content={SITE.tracking.bingVerification} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preload" href="/fonts/instrument-sans-1.woff2" as="font" type="font/woff2" crossorigin />

    {graph && <script type="application/ld+json" set:html={graph} />}
    <ConsentAnalytics />
  </head>
  <body>
    <a class="skip-link" href="#main">{locale === 'de' ? 'Zum Inhalt springen' : locale === 'fr' ? 'Aller au contenu' : locale === 'it' ? 'Vai al contenuto' : 'Skip to content'}</a>
    <Header locale={locale} localePaths={lp} availableLocales={availableLocales} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <!-- Mobile-only persistent CTA: header actions collapse into the hamburger,
         so this keeps a call/demo tap target in view after the hero scrolls off. -->
    <div class="mcta">
      <a class="btn btn--primary" href={`tel:${SITE.aiPhone}`} data-track="call_ai_live">{t(locale, 'cta.call')}</a>
      <a class="btn btn--secondary" href={`${localePrefix(locale)}/kontakt/`} data-track="request_demo">{t(locale, 'nav.cta')}</a>
    </div>
    <ConsentBanner locale={locale} />
    <script is:inline>
      // Scroll reveal: only arms when motion is allowed; otherwise content stays
      // visible (progressive enhancement, accessibility-safe).
      (function () {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var els = document.querySelectorAll('.reveal');
        if (!els.length || !('IntersectionObserver' in window)) return;
        els.forEach(function (el) { el.classList.add('reveal--armed'); });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
    <style>
      /* Mobile-only persistent CTA bar (hidden from 920px, where header actions return). */
      .mcta {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 70; /* below ConsentBanner (90), so consent still wins on first load */
        display: flex;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem calc(0.5rem + env(safe-area-inset-bottom));
        background: var(--paper);
        border-top: 1px solid var(--line);
      }
      .mcta a { flex: 1; justify-content: center; min-height: 48px; }
      @media (min-width: 920px) { .mcta { display: none; } }
      /* Reserve space so the fixed bar never covers the footer on mobile. */
      @media (max-width: 919px) { :global(body) { padding-bottom: 64px; } }
    </style>
  </body>
</html>
